---
import Button from "../components/design-system/Button.astro";
import SectionLabel from "../components/design-system/SectionLabel.astro";
import SiteHeader from "../components/design-system/SiteHeader.astro";
import StatusLabel from "../components/design-system/StatusLabel.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const navItems = [
	{ label: "Vision", href: "/#vision" },
	{ label: "Why Mythadis", href: "/why-mythadis/" },
	{ label: "Proof", href: "/proof/" },
	{ label: "Current State", href: "/current-state/" },
	{ label: "Collaborate", href: "/#collaborate" },
];

const proofTimeline = [
	"AI Consensus",
	"AI Debate Arena",
	"AI Council",
	"AI HomeGuard",
	"Profit Pulse",
	"Mythadis Swarm",
	"Mythadis Website",
];

type StatusTone = "blue" | "amber" | "green" | "plum";

interface ProofRecord {
	name: string;
	status: string;
	tone: StatusTone;
	purpose: string;
	maturity: string;
	evidence: string;
	repository: string;
	lessons: string;
	next: string;
}

const proofRecords: ProofRecord[] = [
	{
		name: "AI Consensus",
		status: "Released",
		tone: "green",
		purpose: "Compare multiple LLM responses and synthesize agreement, disagreement, uncertainty, and follow-up questions.",
		maturity: "Public local-first MVP. Current GitHub release is v0.1.1.",
		evidence: "FastAPI backend, React/Vite frontend, OpenAI and Gemini provider support, Docker Compose, Markdown export, validation notes, and release documentation.",
		repository: "https://github.com/blanzy-labs/ai-consensus",
		lessons: "Consensus is useful only when disagreement remains visible. A proof layer must preserve uncertainty instead of smoothing it away.",
		next: "Validation polish and focused local-first improvements.",
	},
	{
		name: "AI Debate Arena",
		status: "Released",
		tone: "green",
		purpose: "Run structured multi-perspective AI debates with opening arguments, rebuttals, and a judge synthesis.",
		maturity: "Public local-first MVP. Current GitHub release is v0.1.1.",
		evidence: "FastAPI backend, React/Vite frontend, OpenAI and Gemini provider support, four debate modes, Docker Compose, safe error handling, and Markdown export.",
		repository: "https://github.com/blanzy-labs/ai-debate-arena",
		lessons: "Structured disagreement exposes assumptions and tradeoffs earlier than a single-answer interface.",
		next: "Continue improving validation, debate modes, and documentation discipline.",
	},
	{
		name: "AI Council",
		status: "Released",
		tone: "green",
		purpose: "Create a local-first multi-persona council room for structured discussion, critique, follow-up chat, live activity, and transcript export.",
		maturity: "Public local-first MVP. Current GitHub release is v0.1.2.",
		evidence: "FastAPI backend, React/Vite frontend, mock provider, OpenAI provider, persona registry, in-memory sessions, Server-Sent Events, Markdown and JSON export.",
		repository: "https://github.com/blanzy-labs/ai-council",
		lessons: "Useful AI collaboration needs roles, memory boundaries, exportable transcripts, and safe local defaults.",
		next: "Voice experiments and provider adapter exploration remain future work.",
	},
	{
		name: "AI HomeGuard",
		status: "Released MVP",
		tone: "green",
		purpose: "Help home users review common cyber hygiene basics through local checks, guided questions, defensive guidance, and safe network awareness.",
		maturity: "Public local-first MVP documented as v0.1.0.",
		evidence: "FastAPI backend, React/Vite frontend, platform-aware local audit foundations, questionnaire reports, D3FEND-informed guidance, bounded private-network discovery, Markdown and JSON export.",
		repository: "https://github.com/blanzy-labs/ai-homeguard",
		lessons: "Safety boundaries matter. Defensive tools need explicit authorization, conservative scope, and clear limitations.",
		next: "Native-platform validation and continued safety review.",
	},
	{
		name: "Profit Pulse",
		status: "Commissioned MVP",
		tone: "amber",
		purpose: "Address a real customer problem around practical business decision support.",
		maturity: "Commissioned MVP under current development. No public repository is available.",
		evidence: "Founder-confirmed commissioned work. Public technical evidence is not yet available, so the page does not present repository or release claims.",
		repository: "",
		lessons: "Commercial work creates a sharper test: the system must solve a real operational problem, not only demonstrate a technical pattern.",
		next: "Complete the MVP slice and decide what can be publicly documented without exposing customer details.",
	},
	{
		name: "Mythadis Swarm",
		status: "Demonstrated Prototype",
		tone: "amber",
		purpose: "Explore a decentralized semantic data, storage, compute, and intelligence substrate for coordinated work.",
		maturity: "Private Rust research prototype. Not public, not production-ready, and no public Agent is available.",
		evidence: "Private repository with libp2p nodes, lightweight Neural Index gossip, Kademlia storage experiments, Reed-Solomon sharding, Data Parcels, profiles, ingestion, query, HTTP, CLI, and observability modules.",
		repository: "Private repository",
		lessons: "The core challenge is not only moving data between nodes. It is making distributed evidence discoverable, recoverable, and useful.",
		next: "Mission Control, Agents, Data Parcels, Annals, and Mission Swarms remain active proof gates.",
	},
	{
		name: "Mythadis Website",
		status: "Released",
		tone: "green",
		purpose: "Provide a public surface for the Mythadis mission, current state, founder reasoning, and proof discipline.",
		maturity: "Public Astro site deployed through Cloudflare Pages.",
		evidence: "Static Astro build, approved Luminous Archive visual system, release screenshots, founder-reviewed pages, Cloudflare production deployment, and GitHub workflow.",
		repository: "https://github.com/blanzy-labs/mythadis-site",
		lessons: "A serious public surface must be honest about maturity while still making the work legible.",
		next: "Continue adding founder-approved pages that replace claims with evidence.",
	},
];

const swarmEvidence = [
	"Cross-platform local or containerized Rust node deployment",
	"Multiple libp2p node communication",
	"LAN swarm validation through Docker Compose demo nodes",
	"Distributed storage experiments using Kademlia",
	"Data recovery experiments using Reed-Solomon shards",
	"Mission Control foundations through HTTP status, catalog, parcel, ingest, hunt, and ask surfaces",
	"Archive Health foundations through catalog, parcel lookup, content hashes, and source-grounded responses",
];

const swarmLimitations = [
	"Private research prototype",
	"No public production network",
	"No public Mythadis Agent",
	"No production authentication or encryption layer yet",
	"No reputation, incentives, workflow execution, or Kubernetes layer yet",
	"No biomedical logic or medical advice behavior",
];

const principles = [
	{
		title: "Validation",
		body: "Every release page records checks, builds, deployment behavior, screenshots, and known limitations.",
	},
	{
		title: "Slices",
		body: "Work is narrowed into demonstrable slices before broader claims are made.",
	},
	{
		title: "Approval Gates",
		body: "Founder review is explicit before public release, and production deployment happens through reviewed pull requests.",
	},
	{
		title: "Repository Health",
		body: "README files, validation notes, security notes, release checklists, and scoped branches are treated as part of the work.",
	},
	{
		title: "Design Systems",
		body: "The public site uses the approved Luminous Archive system rather than inventing a new visual language for each page.",
	},
	{
		title: "Documentation",
		body: "Evidence is preserved in public docs when possible and marked private or unavailable when it cannot be shown.",
	},
];

const currentWork = [
	"Mythadis Website",
	"Private R&D",
	"Early prototypes",
	"No public Agent",
	"Future Mission Swarms",
];

const nextItems = [
	{ name: "Mission Control", status: "In Development" },
	{ name: "Agents", status: "Research Direction" },
	{ name: "Data Parcels", status: "In Development" },
	{ name: "Annals", status: "Future Gate" },
	{ name: "Mission Swarms", status: "Future Gate" },
];
---

<BaseLayout
	title="Proof | Mythadis"
	description="Demonstrated Mythadis work, released systems, current prototypes, and the evidence behind the public vision."
>
	<div class="ds-shell proof-page">
		<SiteHeader
			items={navItems}
			brandLabel="Mythadis"
			brandSubLabel="Swarm"
			status="Demonstrated work"
		/>

		<main>
			<section class="proof-hero" aria-labelledby="page-title">
				<StatusLabel tone="green">Demonstrated Work</StatusLabel>
				<h1 id="page-title">Proof</h1>
				<div class="hero-lines" aria-label="Proof statement">
					<p>Mythadis measures progress differently.</p>
					<p>Vision inspires.</p>
					<p>Proof earns trust.</p>
				</div>
				<p class="proof-line">Evidence before legend.</p>
			</section>

			<section class="why-proof" aria-labelledby="why-proof-title">
				<SectionLabel>Why Proof?</SectionLabel>
				<h2 id="why-proof-title">Large visions are common. Working systems are rare.</h2>
				<div class="why-proof-copy">
					<p>
						The purpose of Mythadis is not to make increasingly ambitious claims. The purpose
						is to preserve evidence of progress.
					</p>
					<p>
						This page records what has been built, what has been released, what has been
						validated, and what remains under development.
					</p>
				</div>
			</section>

			<section class="timeline-section" aria-labelledby="timeline-title">
				<div class="section-heading">
					<SectionLabel>Current Demonstrated Work</SectionLabel>
					<h2 id="timeline-title">A trail of working slices.</h2>
				</div>
				<ol class="proof-timeline">
					{proofTimeline.map((item) => (
						<li>
							<span>{item}</span>
						</li>
					))}
				</ol>
			</section>

			<section class="swarm-section" aria-labelledby="swarm-title">
				<div class="swarm-intro">
					<StatusLabel tone="amber">Demonstrated Prototype</StatusLabel>
					<h2 id="swarm-title">Mythadis Swarm</h2>
					<p>
						Mythadis Swarm is a private Rust research prototype exploring decentralized
						semantic data, storage, compute, and intelligence coordination. It is demonstrated
						work, not a production network.
					</p>
				</div>
				<div class="swarm-grids">
					<div class="evidence-list">
						<h3>Validated foundations</h3>
						<ul>
							{swarmEvidence.map((item) => <li>{item}</li>)}
						</ul>
					</div>
					<div class="evidence-list evidence-list--limits">
						<h3>Current limitations</h3>
						<ul>
							{swarmLimitations.map((item) => <li>{item}</li>)}
						</ul>
					</div>
				</div>
			</section>

			<section class="records-section" aria-labelledby="records-title">
				<div class="section-heading">
					<SectionLabel>Evidence Panels</SectionLabel>
					<h2 id="records-title">Expandable proof records.</h2>
				</div>
				<div class="proof-records">
					{proofRecords.map((record) => (
						<details class="proof-record">
							<summary>
								<span>{record.name}</span>
								<StatusLabel tone={record.tone}>{record.status}</StatusLabel>
							</summary>
							<div class="record-grid">
								<div>
									<h3>Purpose</h3>
									<p>{record.purpose}</p>
								</div>
								<div>
									<h3>Current maturity</h3>
									<p>{record.maturity}</p>
								</div>
								<div>
									<h3>Evidence</h3>
									<p>{record.evidence}</p>
								</div>
								<div>
									<h3>Repository</h3>
									{record.repository.startsWith("https://") ? (
										<a href={record.repository} rel="noreferrer">{record.repository}</a>
									) : (
										<p>{record.repository || "Not public"}</p>
									)}
								</div>
								<div>
									<h3>Lessons learned</h3>
									<p>{record.lessons}</p>
								</div>
								<div>
									<h3>Next milestone</h3>
									<p>{record.next}</p>
								</div>
							</div>
						</details>
					))}
				</div>
			</section>

			<section class="principles-section" aria-labelledby="principles-title">
				<div class="section-heading">
					<SectionLabel>Engineering Principles</SectionLabel>
					<h2 id="principles-title">The process is part of the evidence.</h2>
				</div>
				<div class="principles-grid">
					{principles.map((principle) => (
						<article>
							<h3>{principle.title}</h3>
							<p>{principle.body}</p>
						</article>
					))}
				</div>
			</section>

			<section class="current-work-section" aria-labelledby="current-work-title">
				<div>
					<SectionLabel>Current Work</SectionLabel>
					<h2 id="current-work-title">The public site connects back to the actual state.</h2>
					<p>
						Mythadis is public about what exists and what does not. The website is released.
						The swarm is private R&D. The Agent is not public. Future Mission Swarms remain
						future work.
					</p>
				</div>
				<ul class="current-work-list">
					{currentWork.map((item) => <li>{item}</li>)}
				</ul>
			</section>

			<section class="next-section" aria-labelledby="next-title">
				<div class="section-heading">
					<SectionLabel>What's Next</SectionLabel>
					<h2 id="next-title">Currently being proven.</h2>
				</div>
				<div class="next-grid">
					{nextItems.map((item) => (
						<div>
							<h3>{item.name}</h3>
							<span>{item.status}</span>
						</div>
					))}
				</div>
			</section>

			<section class="work-declaration" aria-labelledby="work-title">
				<h2 id="work-title">The Work</h2>
				<div class="work-copy">
					<p>Every project begins as an idea.</p>
					<p>Mythadis advances only when ideas become working systems.</p>
					<p>
						We measure ourselves by what can be demonstrated today&mdash;not by what we hope
						to achieve tomorrow.
					</p>
				</div>
				<p class="closing-line">Evidence before legend.</p>
				<div class="journey-cta" aria-label="Continue the journey">
					<span>Continue the journey</span>
					<span aria-hidden="true">&darr;</span>
					<Button href="/current-state/" variant="secondary">Current State</Button>
				</div>
			</section>
		</main>

		<footer class="proof-footer">
			<p>Proof earns trust.</p>
			<nav aria-label="Footer navigation">
				<a href="/why-mythadis/">Why Mythadis</a>
				<a href="/field-reports/">Field Reports</a>
			</nav>
		</footer>
	</div>
</BaseLayout>

<style>
	h1,
	h2,
	h3,
	p {
		text-wrap: pretty;
	}

	h1,
	h2,
	h3 {
		margin: 0;
		font-family: var(--ds-font-display);
		letter-spacing: 0;
	}

	.proof-hero {
		display: grid;
		align-content: center;
		min-height: calc(100svh - 84px);
		padding: 62px 0 118px;
	}

	.proof-hero h1 {
		margin-top: 28px;
		font-size: clamp(5.8rem, 16vw, 16rem);
		line-height: 0.78;
	}

	.hero-lines {
		display: grid;
		gap: 12px;
		max-width: 820px;
		margin-top: 54px;
		color: var(--ds-ink-soft);
		font-family: var(--ds-font-display);
		font-size: clamp(1.65rem, 3.6vw, 3.6rem);
		font-weight: 700;
		line-height: 1;
	}

	.hero-lines p,
	.proof-line,
	.why-proof p,
	.swarm-intro p,
	.evidence-list p,
	.evidence-list li,
	.record-grid p,
	.principles-grid p,
	.current-work-section p,
	.work-copy p,
	.closing-line,
	.proof-footer p {
		margin: 0;
	}

	.hero-lines p:last-child,
	.proof-line,
	.closing-line {
		color: var(--ds-mint);
	}

	.proof-line {
		margin-top: 34px;
		padding-top: 24px;
		border-top: 1px solid var(--ds-line-strong);
		font-family: var(--ds-font-display);
		font-size: clamp(2rem, 4.8vw, 5rem);
		font-weight: 700;
		line-height: 0.95;
	}

	.why-proof,
	.timeline-section,
	.swarm-section,
	.records-section,
	.principles-section,
	.current-work-section,
	.next-section {
		padding: 0 0 118px;
	}

	.why-proof {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(280px, 0.7fr);
		gap: 42px;
		align-items: end;
	}

	.why-proof h2,
	.section-heading h2,
	.swarm-intro h2,
	.current-work-section h2,
	.next-section h2 {
		font-size: clamp(2.55rem, 5.9vw, 6.4rem);
		line-height: 0.9;
	}

	.why-proof > .ds-section-label {
		grid-column: 1 / -1;
	}

	.why-proof-copy {
		display: grid;
		gap: 18px;
	}

	.why-proof-copy p,
	.swarm-intro p,
	.record-grid p,
	.principles-grid p,
	.current-work-section p {
		color: var(--ds-ink-soft);
		font-size: clamp(1.02rem, 1.4vw, 1.18rem);
		line-height: 1.72;
	}

	.section-heading {
		max-width: 920px;
		margin-bottom: 34px;
	}

	.proof-timeline {
		display: grid;
		grid-template-columns: repeat(7, 1fr);
		gap: 0;
		margin: 0;
		padding: 0;
		list-style: none;
		border: 1px solid var(--ds-line-strong);
		background: rgba(2, 7, 10, 0.34);
	}

	.proof-timeline li {
		position: relative;
		display: grid;
		align-content: end;
		min-height: 260px;
		padding: 20px;
		border-right: 1px solid var(--ds-line);
	}

	.proof-timeline li:last-child {
		border-right: 0;
	}

	.proof-timeline li:not(:last-child)::after {
		position: absolute;
		top: 50%;
		right: -9px;
		z-index: 2;
		width: 18px;
		height: 18px;
		content: "";
		border-top: 1px solid var(--ds-blue);
		border-right: 1px solid var(--ds-blue);
		background: var(--ds-void);
		transform: translateY(-50%) rotate(45deg);
	}

	.proof-timeline li::before {
		position: absolute;
		top: 18px;
		left: 18px;
		color: var(--ds-blue);
		font-family: var(--ds-font-mono);
		font-size: 0.68rem;
		content: "0" counter(list-item);
	}

	.proof-timeline span {
		font-family: var(--ds-font-display);
		font-size: clamp(1.1rem, 1.8vw, 1.55rem);
		font-weight: 700;
		line-height: 1.04;
	}

	.swarm-section {
		border-block: 1px solid var(--ds-line-strong);
		margin-bottom: 118px;
		padding: 86px 0;
		background:
			linear-gradient(90deg, rgba(66, 217, 255, 0.08), transparent 36%),
			linear-gradient(180deg, rgba(2, 7, 10, 0.14), rgba(2, 7, 10, 0.5));
	}

	.swarm-intro {
		max-width: 980px;
	}

	.swarm-intro h2 {
		margin-top: 20px;
	}

	.swarm-intro p {
		max-width: 760px;
		margin-top: 26px;
	}

	.swarm-grids {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 22px;
		margin-top: 48px;
	}

	.evidence-list {
		padding: 26px;
		border: 1px solid var(--ds-line);
		background: rgba(10, 22, 28, 0.72);
	}

	.evidence-list--limits {
		border-color: rgba(246, 197, 107, 0.28);
		background: linear-gradient(120deg, rgba(246, 197, 107, 0.06), rgba(10, 22, 28, 0.72));
	}

	.evidence-list h3,
	.record-grid h3,
	.principles-grid h3,
	.next-grid h3 {
		font-size: clamp(1.3rem, 2vw, 1.85rem);
		line-height: 1.05;
	}

	.evidence-list ul,
	.current-work-list {
		display: grid;
		gap: 12px;
		margin: 24px 0 0;
		padding: 0;
		list-style: none;
	}

	.evidence-list li,
	.current-work-list li {
		padding-top: 12px;
		border-top: 1px solid var(--ds-line);
		color: var(--ds-ink-soft);
		line-height: 1.5;
	}

	.proof-records {
		display: grid;
		gap: 12px;
	}

	.proof-record {
		border: 1px solid var(--ds-line);
		background: rgba(10, 22, 28, 0.72);
	}

	.proof-record summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 18px;
		min-height: 74px;
		padding: 18px 22px;
		cursor: pointer;
		font-family: var(--ds-font-display);
		font-size: clamp(1.2rem, 2vw, 1.75rem);
		font-weight: 700;
	}

	.proof-record summary::marker {
		color: var(--ds-blue);
	}

	.record-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 22px;
		padding: 0 22px 24px;
	}

	.record-grid > div {
		padding-top: 18px;
		border-top: 1px solid var(--ds-line);
	}

	.record-grid p,
	.record-grid a {
		display: inline-block;
		margin-top: 10px;
	}

	.record-grid a {
		color: var(--ds-ink);
		line-height: 1.45;
		border-bottom: 1px solid var(--ds-blue);
	}

	.principles-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 16px;
	}

	.principles-grid article,
	.next-grid div {
		min-height: 210px;
		padding: 22px;
		border: 1px solid var(--ds-line);
		background: rgba(10, 22, 28, 0.7);
	}

	.principles-grid p {
		margin-top: 18px;
	}

	.current-work-section {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(260px, 0.55fr);
		gap: 42px;
		align-items: start;
	}

	.current-work-section p {
		max-width: 760px;
		margin-top: 24px;
	}

	.current-work-list {
		margin-top: 10px;
	}

	.current-work-list li {
		color: var(--ds-ink);
		font-family: var(--ds-font-mono);
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.next-grid {
		display: grid;
		grid-template-columns: repeat(5, 1fr);
		gap: 14px;
	}

	.next-grid div {
		display: grid;
		align-content: space-between;
		min-height: 190px;
	}

	.next-grid span {
		color: var(--ds-amber);
		font-family: var(--ds-font-mono);
		font-size: 0.68rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.work-declaration {
		display: grid;
		justify-items: start;
		min-height: 84svh;
		padding: 98px 0 128px;
		border-top: 1px solid var(--ds-line-strong);
	}

	.work-declaration h2 {
		color: var(--ds-blue);
		font-size: clamp(1.1rem, 1.8vw, 1.5rem);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.work-copy {
		display: grid;
