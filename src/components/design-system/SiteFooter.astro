---
interface Props {
	secondary?: string;
}

const { secondary = "Blanzy Labs / Static Astro foundation" } = Astro.props;
---

<footer class="ds-site-footer">
	<p><slot>Mythadis design system. Derived from The Luminous Archive.</slot></p>
	<p>{secondary}</p>
</footer>

<style>
	.ds-site-footer {
		display: flex;
		justify-content: space-between;
		gap: 20px;
		padding: 34px 0 46px;
		border-top: 1px solid var(--ds-line);
		color: var(--ds-ink-muted);
		font-size: 0.86rem;
	}

	.ds-site-footer p {
		margin: 0;
	}

	@media (max-width: 620px) {
		.ds-site-footer {
			flex-direction: column;
		}
	}
</style>
