---
import "@fontsource/manrope/400.css";
import "@fontsource/manrope/500.css";
import "@fontsource/manrope/700.css";
import "@fontsource/source-sans-3/400.css";
import "@fontsource/source-sans-3/500.css";
import "@fontsource/source-sans-3/700.css";
import "@fontsource/newsreader/400.css";
import "@fontsource/newsreader/500.css";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
---

<!doctype html>
<html lang="en" data-theme="living-atlas">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Mythadis visual study B, The Living Atlas: an editorial atlas direction for distributed intelligence and evidence."
		/>
		<meta name="robots" content="noindex, nofollow" />
		<title>Mythadis Visual Study B | The Living Atlas</title>
	</head>
	<body>
		<div class="atlas-page">
			<header class="atlas-header" aria-label="Primary">
				<a class="brand" href="/" aria-label="Mythadis comparison page">
					<span class="brand-grid" aria-hidden="true">
						<span></span>
						<span></span>
					</span>
					<span>
						<strong>Mythadis</strong>
						<small>Visual Study B</small>
					</span>
				</a>
				<nav class="atlas-nav" aria-label="Study sections">
					<a href="#atlas">Atlas</a>
					<a href="#doctrine">Doctrine</a>
					<a href="#surfaces">Catalog</a>
					<a href="/visual-study-a/">Study A</a>
				</nav>
				<p class="research-state">Private research</p>
			</header>

			<main>
				<section class="hero" id="atlas" aria-labelledby="page-title">
					<div class="hero-index" aria-label="Study metadata">
						<p>MWEB-003B</p>
						<p>Living Atlas</p>
						<p>Coordinate ref. MYT / B-02</p>
					</div>

					<div class="hero-copy">
						<p class="section-label">Independent knowledge becoming connected and legible.</p>
						<h1 id="page-title">A living atlas for coordinated intelligence.</h1>
						<p class="mission">
							How do we organize intelligence&mdash;human and artificial&mdash;so that together
							we can solve problems that neither could solve alone?
						</p>
						<p class="supporting-line">
							Many minds. Many machines. Many models. One proof-first fabric.
						</p>
						<div class="actions" aria-label="Primary study actions">
							<a class="button primary" href="#doctrine">Read doctrine</a>
							<a class="button secondary" href="#surfaces">Inspect system</a>
						</div>
					</div>

					<aside class="atlas-map" aria-label="Abstract atlas diagram">
						<div class="map-header">
							<span>Atlas sheet 02</span>
							<span>Evidence routes</span>
						</div>
						<svg viewBox="0 0 680 520" role="img" aria-labelledby="map-title map-desc">
							<title id="map-title">Living atlas map</title>
							<desc id="map-desc">
								A precise scientific map with routes, evidence plots, and annotated regions.
							</desc>
							<defs>
								<pattern id="atlasGrid" width="34" height="34" patternUnits="userSpaceOnUse">
									<path d="M34 0H0V34" fill="none" stroke="rgba(187,198,204,.12)" stroke-width="1" />
								</pattern>
								<linearGradient id="route" x1="0%" y1="0%" x2="100%" y2="0%">
									<stop offset="0%" stop-color="#5ed6d1" />
									<stop offset="58%" stop-color="#4c9eff" />
									<stop offset="100%" stop-color="#8b83e8" />
								</linearGradient>
							</defs>
							<rect x="28" y="28" width="624" height="464" rx="2" class="map-field" />
							<rect x="28" y="28" width="624" height="464" fill="url(#atlasGrid)" opacity=".78" />
							<path d="M92 404 C162 328 178 248 254 234 S356 274 422 188 S526 120 598 174" class="route wide" />
							<path d="M92 404 C162 328 178 248 254 234 S356 274 422 188 S526 120 598 174" class="route" />
							<path d="M126 132 L238 96 L316 146 L418 108 L548 136" class="boundary" />
							<path d="M146 356 L248 332 L356 382 L476 330 L570 360" class="boundary muted" />
							<g class="plot-lines">
								<path d="M98 82H232" />
								<path d="M98 104H184" />
								<path d="M438 424H586" />
								<path d="M492 446H586" />
							</g>
							<g class="points">
								<circle cx="92" cy="404" r="8" />
								<circle cx="254" cy="234" r="8" />
								<circle cx="422" cy="188" r="8" />
								<circle cx="598" cy="174" r="8" />
								<circle cx="316" cy="146" r="5" />
								<circle cx="476" cy="330" r="5" />
							</g>
							<g class="annotations">
								<path d="M254 234H340" />
								<path d="M422 188H500" />
								<path d="M92 404H176" />
								<text x="348" y="239">MODEL CLUSTER</text>
								<text x="508" y="193">PROOF ROUTE</text>
								<text x="184" y="409">OBSERVED NODE</text>
							</g>
							<text x="52" y="474" class="map-label">UNITY WITHOUT CENTRALIZATION</text>
							<text x="424" y="474" class="map-label">EVIDENCE BEFORE LEGEND</text>
						</svg>
						<div class="map-footer">
							<span>Legibility index: 0.82</span>
							<span>Fabric state: early</span>
						</div>
					</aside>
				</section>

				<section class="product-line" aria-label="Product description">
					<p>Mythadis exists to coordinate intelligence&mdash;not just computation.</p>
				</section>

				<section class="doctrine-section" id="doctrine" aria-labelledby="doctrine-title">
					<div class="section-heading">
						<p class="section-label">Core doctrine</p>
						<h2 id="doctrine-title">Institutional structure for distributed proof.</h2>
					</div>

					<div class="doctrine-layout">
						<article class="quote-card">
							<p class="card-label">Governing phrase</p>
							<h3>Unity without centralization.</h3>
							<p>
								A visual system for alignment without command: routes, records, and regions
								make relation visible while preserving independent centers of work.
							</p>
						</article>

						<article class="catalog-card">
							<p class="card-label">Proof doctrine</p>
							<h3>Evidence before legend.</h3>
							<p>
								Claims should read as cataloged, inspectable, and provisional until proof is clear.
							</p>
						</article>

						<article class="status-panel">
							<p class="card-label">Current status</p>
							<h3>Mythadis Swarm is currently private research and engineering.</h3>
							<ul>
								<li>Not production-ready</li>
								<li>Not yet a public volunteer network</li>
								<li>Mythadis Agent is not publicly available</li>
							</ul>
						</article>
					</div>
				</section>

				<section class="catalog-section" id="surfaces" aria-labelledby="surfaces-title">
					<div class="section-heading">
						<p class="section-label">Interface primitives</p>
						<h2 id="surfaces-title">Atlas-like surfaces for long-form research.</h2>
					</div>

					<div class="catalog-grid">
						<article class="catalog-item">
							<div class="item-index">01</div>
							<div>
								<span class="status-pill">Prototype</span>
								<h3>Evidence Register</h3>
								<p>Structured records for claims, observations, and proof trails.</p>
							</div>
						</article>
						<article class="catalog-item">
							<div class="item-index">02</div>
							<div>
								<span class="status-pill blue">Review</span>
								<h3>Coordination Atlas</h3>
								<p>Maps relationships between minds, machines, models, and mission work.</p>
							</div>
						</article>
						<article class="catalog-item">
							<div class="item-index">03</div>
							<div>
								<span class="status-pill gold">Stable token</span>
								<h3>Annals Surface</h3>
								<p>Readable editorial space for doctrine, research programs, and architecture.</p>
							</div>
						</article>
					</div>
				</section>
			</main>

			<footer class="atlas-footer">
				<div>
					<strong>Mythadis Labs</strong>
					<p>Visual Study B: The Living Atlas. Built for controlled founder review.</p>
				</div>
				<a href="/">Compare studies</a>
			</footer>
		</div>
	</body>
</html>

<style>
	:root[data-theme="living-atlas"] {
		--font-display: "Manrope", system-ui, sans-serif;
		--font-body: "Source Sans 3", "Inter", system-ui, sans-serif;
		--font-accent: "Newsreader", Georgia, serif;
		--font-mono: "IBM Plex Mono", "SFMono-Regular", Consolas, monospace;
		--atlas-deep: #07101a;
		--atlas-field: #0b1724;
		--atlas-surface: #111f2e;
		--atlas-raised: #17293b;
		--atlas-text-primary: #f1f3ee;
		--atlas-text-secondary: #bbc6cc;
		--atlas-text-muted: #7f919d;
		--atlas-signal-cyan: #5ed6d1;
		--atlas-signal-blue: #4c9eff;
		--atlas-intelligence-violet: #8b83e8;
		--atlas-proof-gold: #c4a46a;
		--atlas-warning: #d4a054;
		--atlas-critical: #d87575;
		--atlas-rule: rgba(187, 198, 204, 0.16);
		--atlas-rule-strong: rgba(187, 198, 204, 0.28);
		--max-page: 1220px;
		color-scheme: dark;
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-width: 320px;
		font-family: var(--font-body);
		color: var(--atlas-text-primary);
		background:
			linear-gradient(rgba(187, 198, 204, 0.05) 1px, transparent 1px),
			linear-gradient(90deg, rgba(187, 198, 204, 0.045) 1px, transparent 1px),
			radial-gradient(circle at 76% 18%, rgba(94, 214, 209, 0.12), transparent 28rem),
			linear-gradient(145deg, var(--atlas-deep), var(--atlas-field) 48%, #091522);
		background-size: 56px 56px, 56px 56px, auto, auto;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.atlas-page {
		width: min(100% - 32px, var(--max-page));
		margin: 0 auto;
	}

	.atlas-header {
		display: grid;
		grid-template-columns: 1fr auto auto;
		gap: 28px;
		align-items: center;
		min-height: 90px;
		border-bottom: 1px solid var(--atlas-rule);
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 14px;
		font-family: var(--font-display);
	}

	.brand strong,
	.brand small {
		display: block;
	}

	.brand small {
		margin-top: 2px;
		color: var(--atlas-text-muted);
		font-family: var(--font-mono);
		font-size: 0.65rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.brand-grid {
		position: relative;
		display: block;
		width: 38px;
		height: 38px;
		border: 1px solid var(--atlas-rule-strong);
		background:
			linear-gradient(90deg, transparent 48%, rgba(94, 214, 209, 0.56) 49% 51%, transparent 52%),
			linear-gradient(transparent 48%, rgba(94, 214, 209, 0.56) 49% 51%, transparent 52%),
			var(--atlas-surface);
	}

	.brand-grid span {
		position: absolute;
		width: 7px;
		height: 7px;
		background: var(--atlas-signal-cyan);
	}

	.brand-grid span:first-child {
		top: 7px;
		right: 8px;
	}

	.brand-grid span:last-child {
		left: 8px;
		bottom: 8px;
		background: var(--atlas-intelligence-violet);
	}

	.atlas-nav {
		display: flex;
		gap: 24px;
		font-family: var(--font-display);
		color: var(--atlas-text-secondary);
		font-size: 0.92rem;
	}

	.atlas-nav a {
		padding-block: 10px;
		border-bottom: 1px solid transparent;
	}

	.atlas-nav a:hover,
	.atlas-nav a:focus-visible {
		color: var(--atlas-text-primary);
		border-color: var(--atlas-signal-cyan);
	}

	.research-state,
	.hero-index,
	.section-label,
	.card-label,
	.status-pill,
	.item-index,
	.map-header,
	.map-footer,
	.map-label,
	.annotations text {
		font-family: var(--font-mono);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.research-state {
		margin: 0;
		padding: 8px 10px;
		border: 1px solid rgba(196, 164, 106, 0.42);
		color: var(--atlas-proof-gold);
		background: rgba(196, 164, 106, 0.08);
		font-size: 0.68rem;
	}

	.hero {
		display: grid;
		grid-template-columns: 132px minmax(0, 0.82fr) minmax(460px, 1fr);
		gap: 28px;
		align-items: stretch;
		padding: 58px 0 72px;
	}

	.hero-index {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		margin: 0;
		padding: 18px 0;
		border-block: 1px solid var(--atlas-rule);
		color: var(--atlas-text-muted);
		font-size: 0.66rem;
	}

	.hero-index p {
		margin: 0;
		writing-mode: vertical-rl;
		transform: rotate(180deg);
	}

	.hero-copy {
		align-self: center;
		padding-block: 24px;
	}

	.section-label,
	.card-label {
		margin: 0 0 16px;
		color: var(--atlas-signal-cyan);
		font-size: 0.7rem;
	}

	h1,
	h2,
	h3,
	p {
		text-wrap: pretty;
	}

	h1,
	h2,
	h3 {
		margin: 0;
		font-family: var(--font-display);
		letter-spacing: 0;
	}

	h1 {
		max-width: 10ch;
		font-size: clamp(3.15rem, 5.7vw, 5.45rem);
		line-height: 0.94;
	}

	.mission {
		max-width: 700px;
		margin: 30px 0 0;
		color: var(--atlas-text-secondary);
		font-family: var(--font-accent);
		font-size: clamp(1.28rem, 2.1vw, 1.62rem);
		line-height: 1.42;
	}

	.supporting-line {
		max-width: 590px;
		margin: 18px 0 0;
		color: var(--atlas-text-secondary);
		font-size: 1.04rem;
		line-height: 1.55;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 32px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: 0 18px;
		border: 1px solid var(--atlas-rule-strong);
		font-family: var(--font-display);
		font-size: 0.9rem;
		font-weight: 700;
	}

	.button.primary {
		color: #061016;
		background: var(--atlas-signal-cyan);
	}

	.button.secondary {
		color: var(--atlas-text-primary);
		background: transparent;
	}

	.atlas-map {
		align-self: center;
		border: 1px solid var(--atlas-rule-strong);
		background: rgba(17, 31, 46, 0.84);
	}

	.map-header,
	.map-footer {
		display: flex;
		justify-content: space-between;
		gap: 14px;
		padding: 12px 14px;
		color: var(--atlas-text-muted);
		font-size: 0.64rem;
	}

	.map-header {
		border-bottom: 1px solid var(--atlas-rule);
	}

	.map-footer {
		border-top: 1px solid var(--atlas-rule);
	}

	svg {
		display: block;
		width: 100%;
		height: auto;
	}

	.map-field {
		fill: rgba(7, 16, 26, 0.54);
		stroke: var(--atlas-rule-strong);
	}

	.route {
		fill: none;
		stroke: url(#route);
		stroke-width: 3;
	}

	.route.wide {
		stroke-width: 12;
		opacity: 0.08;
	}

	.boundary,
	.plot-lines path,
	.annotations path {
		fill: none;
		stroke: rgba(187, 198, 204, 0.42);
		stroke-width: 1.5;
	}

	.boundary.muted {
		stroke: rgba(94, 214, 209, 0.42);
	}

	.points circle {
		fill: var(--atlas-surface);
		stroke: var(--atlas-signal-cyan);
		stroke-width: 3;
	}

	.points circle:nth-child(3),
	.points circle:nth-child(6) {
		stroke: var(--atlas-intelligence-violet);
	}

	.points circle:nth-child(4) {
		stroke: var(--atlas-proof-gold);
	}

	.annotations text,
	.map-label {
		fill: var(--atlas-text-muted);
		font-size: 10px;
	}

	.product-line {
		padding: 34px 0;
		border-block: 1px solid var(--atlas-rule);
	}

	.product-line p {
		max-width: 970px;
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(2rem, 4.4vw, 4rem);
		font-weight: 700;
		line-height: 1;
	}

	.doctrine-section,
	.catalog-section {
		padding: 96px 0 0;
	}

	.section-heading {
		display: grid;
		grid-template-columns: 180px minmax(0, 1fr);
		gap: 28px;
		align-items: start;
		margin-bottom: 24px;
	}

	.section-heading h2 {
		max-width: 760px;
		font-size: clamp(2rem, 3.8vw, 3.7rem);
		line-height: 1.02;
	}

	.doctrine-layout {
		display: grid;
		grid-template-columns: 1.1fr 0.9fr;
		gap: 16px;
	}

	.quote-card,
	.catalog-card,
	.status-panel,
	.catalog-item {
		border: 1px solid var(--atlas-rule);
		background: var(--atlas-surface);
	}

	.quote-card {
		min-height: 330px;
		padding: 28px;
		background:
			linear-gradient(120deg, rgba(94, 214, 209, 0.12), transparent 46%),
			var(--atlas-surface);
	}

	.quote-card h3 {
		font-family: var(--font-accent);
		font-size: clamp(2.4rem, 4.8vw, 4.6rem);
		font-weight: 500;
		line-height: 0.96;
	}

	.quote-card p:not(.card-label),
	.catalog-card p,
	.status-panel li,
	.catalog-item p {
		color: var(--atlas-text-secondary);
		font-size: 1rem;
		line-height: 1.62;
	}

	.catalog-card,
	.status-panel {
		padding: 24px;
	}

	.status-panel {
		grid-column: 1 / -1;
		display: grid;
		grid-template-columns: minmax(0, 0.88fr) minmax(320px, 1fr);
		gap: 28px;
		background: var(--atlas-raised);
	}

	.status-panel ul {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 10px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.status-panel li {
		min-height: 76px;
		padding: 14px;
		border-left: 3px solid var(--atlas-proof-gold);
		background: rgba(7, 16, 26, 0.36);
	}

	.catalog-grid {
		display: grid;
		gap: 12px;
	}

	.catalog-item {
		display: grid;
		grid-template-columns: 88px minmax(0, 1fr);
		gap: 24px;
		padding: 22px;
		background: rgba(17, 31, 46, 0.74);
	}

	.item-index {
		color: var(--atlas-text-muted);
		font-size: 0.78rem;
	}

	.status-pill {
		display: inline-flex;
		margin-bottom: 14px;
		padding: 5px 8px;
		border: 1px solid rgba(94, 214, 209, 0.36);
		color: var(--atlas-signal-cyan);
		background: rgba(94, 214, 209, 0.08);
		font-size: 0.62rem;
	}

	.status-pill.blue {
		border-color: rgba(76, 158, 255, 0.36);
		color: var(--atlas-signal-blue);
		background: rgba(76, 158, 255, 0.08);
	}

	.status-pill.gold {
		border-color: rgba(196, 164, 106, 0.42);
		color: var(--atlas-proof-gold);
		background: rgba(196, 164, 106, 0.08);
	}

	.catalog-item h3,
	.catalog-card h3,
	.status-panel h3 {
		font-size: clamp(1.35rem, 2.2vw, 2rem);
		line-height: 1.08;
	}

	.atlas-footer {
		display: flex;
		justify-content: space-between;
		gap: 24px;
		margin-top: 104px;
		padding: 30px 0 42px;
		border-top: 1px solid var(--atlas-rule);
		color: var(--atlas-text-muted);
	}

	.atlas-footer strong {
		color: var(--atlas-text-primary);
		font-family: var(--font-display);
	}

	.atlas-footer p {
		margin: 6px 0 0;
	}

	.atlas-footer a {
		color: var(--atlas-signal-cyan);
		font-family: var(--font-display);
	}

	@media (max-width: 1020px) {
		.atlas-header,
		.hero,
		.section-heading,
		.doctrine-layout,
		.status-panel {
			grid-template-columns: 1fr;
		}

		.atlas-nav {
			flex-wrap: wrap;
		}

		.hero-index {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 12px;
		}

		.hero-index p {
			writing-mode: horizontal-tb;
			transform: none;
		}

		.hero-copy {
			padding-block: 0;
		}

		h1 {
			max-width: 12ch;
		}

		.atlas-map {
			max-width: 720px;
		}
