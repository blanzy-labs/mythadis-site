---
import "../styles/global.css";

interface Props {
	title: string;
	description?: string;
	bodyClass?: string;
	noindex?: boolean;
	canonicalUrl?: string;
	imageUrl?: string;
}

const {
	title,
	description = "Mythadis design system and visual foundation.",
	bodyClass = "ds-luminous-background",
	noindex = false,
	canonicalUrl: canonicalUrlProp,
	imageUrl: imageUrlProp,
} = Astro.props;

const canonicalUrl = canonicalUrlProp ?? new URL(Astro.url.pathname, Astro.site).toString();
const imageUrl = imageUrlProp ?? new URL("/mythadis-social-card.png", Astro.site).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta property="og:site_name" content="Mythadis" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:image" content={imageUrl} />
		<meta property="og:image:secure_url" content={imageUrl} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content="Mythadis — Evidence before legend." />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={imageUrl} />
		{noindex && <meta name="robots" content="noindex, nofollow" />}
		<title>{title}</title>
	</head>
	<body class={bodyClass}>
		<slot />
	</body>
</html>
