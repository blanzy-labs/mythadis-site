---
import Button from "../components/design-system/Button.astro";
import NetworkMotif from "../components/design-system/NetworkMotif.astro";
import SectionLabel from "../components/design-system/SectionLabel.astro";
import SiteHeader from "../components/design-system/SiteHeader.astro";
import StatusLabel from "../components/design-system/StatusLabel.astro";
import SurfacePanel from "../components/design-system/SurfacePanel.astro";
import SystemCard from "../components/design-system/SystemCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const navItems = [
	{ label: "Vision", href: "#vision" },
	{ label: "Current State", href: "#current-state" },
	{ label: "Collaborate", href: "#collaborate" },
];
---

<BaseLayout
	title="Mythadis | Private Research and Engineering"
	description="Mythadis exists to coordinate intelligence, not just computation. Mythadis Swarm is currently private research and engineering."
>
	<div class="ds-shell">
		<SiteHeader
			items={navItems}
			brandLabel="Mythadis"
			brandSubLabel="Swarm"
			status="Private R&D"
		/>

		<main>
			<section class="holding-hero" id="vision" aria-labelledby="page-title">
				<div class="hero-copy">
					<SectionLabel>Private research / Early multi-node prototype</SectionLabel>
					<h1 id="page-title">Mythadis exists to coordinate intelligence&mdash;not just computation.</h1>
					<p class="mission">
						How do we organize intelligence&mdash;human and artificial&mdash;so that together
						we can solve problems that neither could solve alone?
					</p>
					<p class="supporting-line">Many minds. Many machines. Many models. One proof-first fabric.</p>
					<div class="actions" aria-label="Primary page actions">
						<Button href="#current-state">Current state</Button>
						<Button href="#collaborate" variant="secondary">Collaborate</Button>
					</div>
				</div>
				<NetworkMotif />
			</section>

			<section class="doctrine-band" aria-label="Core doctrines">
				<p>Unity without centralization.</p>
				<p>Evidence before legend.</p>
			</section>

			<section class="overview-section" aria-labelledby="overview-title">
				<div>
					<SectionLabel>What Mythadis is</SectionLabel>
					<h2 id="overview-title">A proof-first fabric for human and artificial intelligence.</h2>
				</div>
				<div class="overview-copy">
					<p>
						Mythadis is the master vision for coordinating intelligence across people,
						machines, models, evidence, and mission-specific work.
					</p>
					<p>
						Mythadis Swarm is the flagship coordination platform now being explored through
						private research and engineering.
					</p>
				</div>
			</section>

			<section class="state-section" id="current-state" aria-labelledby="state-title">
				<div class="section-heading">
					<SectionLabel>Early. Private. Proof-first.</SectionLabel>
					<h2 id="state-title">The immediate mission is to prove that the fabric works.</h2>
				</div>

				<SurfacePanel variant="warning">
					<div class="state-panel">
						<div>
							<StatusLabel tone="amber">Private R&D · Early multi-node prototype · No public agent</StatusLabel>
							<h3>Mythadis Swarm is currently private research and engineering.</h3>
						</div>
						<div class="state-copy">
							<p>
								Early prototypes are testing peer discovery, communication across heterogeneous
								machines, distributed data storage and recovery, lightweight knowledge discovery,
								archive health, and the foundations of Mission Control.
							</p>
							<p>
								The project is not production-ready. It is not yet a public volunteer network,
								and the Mythadis Agent is not publicly available.
							</p>
							<p>
								The immediate mission is to prove that the fabric works. Larger Mission Swarms
								and humanity-scale outcomes remain future research directions.
							</p>
						</div>
					</div>
				</SurfacePanel>
			</section>

			<section class="signal-section" aria-labelledby="signal-title">
				<div class="section-heading">
					<SectionLabel>Research focus</SectionLabel>
					<h2 id="signal-title">What the private prototypes are testing.</h2>
				</div>
				<div class="ds-grid ds-grid-3">
					<SystemCard title="Peer Discovery" status="Prototype">
						Testing how heterogeneous machines can find and recognize one another without central assumptions.
					</SystemCard>
					<SystemCard title="Archive Health" status="Private R&D" tone="amber">
						Exploring distributed storage, recovery, and lightweight knowledge discovery across early nodes.
					</SystemCard>
					<SystemCard title="Mission Control" status="Foundation" tone="green">
						Establishing the coordination substrate before larger Mission Swarms become public research directions.
					</SystemCard>
				</div>
			</section>

			<section class="collaboration-section" id="collaborate" aria-labelledby="collaborate-title">
				<SurfacePanel variant="strong">
					<div class="collaboration-card">
						<div>
							<SectionLabel>Collaborate</SectionLabel>
							<h2 id="collaborate-title">For research and engineering conversations.</h2>
							<p>
								Mythadis is not seeking public operators yet. Early conversations are most useful
								with research, infrastructure, distributed-systems, archival, and mission-oriented collaborators.
							</p>
						</div>
						<div class="contact-panel">
							<p class="contact-label">Contact path</p>
							<a href="https://github.com/blanzy-labs" rel="noreferrer">github.com/blanzy-labs</a>
							<p>
								Use the Blanzy Labs public GitHub presence as the current collaboration path
								while Mythadis remains private R&D.
							</p>
						</div>
					</div>
				</SurfacePanel>
			</section>
		</main>

		<footer class="public-footer">
			<p>Mythadis Swarm is private research and engineering. No public Mythadis Agent is available.</p>
			<p>Blanzy Labs / Mythadis</p>
		</footer>
	</div>
</BaseLayout>

<style>
	.holding-hero {
		display: grid;
		grid-template-columns: minmax(0, 0.92fr) minmax(390px, 1.08fr);
		gap: 44px;
		align-items: center;
		min-height: calc(100svh - 84px);
		padding: 42px 0 76px;
	}

	.hero-copy {
		max-width: 700px;
	}

	h1,
	h2,
	h3,
	p {
		text-wrap: pretty;
	}

	h1,
	h2,
	h3 {
		margin: 0;
		font-family: var(--ds-font-display);
		letter-spacing: 0;
	}

	h1 {
		max-width: 10ch;
		font-size: clamp(3.6rem, 5.8vw, 5.45rem);
		line-height: 0.9;
	}

	.mission {
		max-width: 640px;
		margin: 28px 0 0;
		color: var(--ds-ink-soft);
		font-size: clamp(1.04rem, 1.7vw, 1.28rem);
		line-height: 1.65;
	}

	.supporting-line {
		margin: 18px 0 0;
		color: var(--ds-ink-muted);
		font-size: 1rem;
		line-height: 1.55;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 34px;
	}

	.doctrine-band {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 18px;
		margin: 0 0 104px;
		padding: 28px 0;
		border-block: 1px solid var(--ds-line);
	}

	.doctrine-band p {
		margin: 0;
		font-family: var(--ds-font-display);
		font-size: clamp(1.7rem, 4.4vw, 3.4rem);
		line-height: 1.04;
	}

	.overview-section,
	.state-section,
	.signal-section,
	.collaboration-section {
		padding: 0 0 112px;
	}

	.overview-section {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1fr);
		gap: 42px;
		align-items: start;
	}

	.overview-section h2,
	.section-heading h2,
	.collaboration-card h2 {
		max-width: 780px;
		font-size: clamp(2rem, 4vw, 4.1rem);
		line-height: 0.98;
	}

	.overview-copy p,
	.state-copy p,
	.collaboration-card p,
	.contact-panel p {
		color: var(--ds-ink-soft);
		font-size: 1rem;
		line-height: 1.68;
	}

	.overview-copy p:first-child,
	.state-copy p:first-child {
		margin-top: 0;
	}

	.section-heading {
		margin-bottom: 28px;
	}

	.state-panel {
		display: grid;
		grid-template-columns: minmax(0, 0.86fr) minmax(320px, 1fr);
		gap: 30px;
		padding: 28px;
	}

	.state-panel h3 {
		margin-top: 24px;
		font-size: clamp(1.6rem, 2.8vw, 2.5rem);
		line-height: 1.02;
	}

	.collaboration-card {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(300px, 0.72fr);
		gap: 32px;
		align-items: start;
		padding: 28px;
	}

	.contact-panel {
		padding: 18px;
		border: 1px solid var(--ds-line);
		background: rgba(2, 7, 10, 0.32);
	}

	.contact-label {
		margin: 0 0 12px;
		color: var(--ds-blue);
		font-family: var(--ds-font-mono);
		font-size: 0.68rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.contact-panel a {
		display: inline-flex;
		margin-bottom: 12px;
		color: var(--ds-ink);
		font-family: var(--ds-font-display);
		font-size: 1.2rem;
		font-weight: 700;
		border-bottom: 1px solid var(--ds-blue);
	}

	.public-footer {
		display: flex;
		justify-content: space-between;
		gap: 20px;
		padding: 34px 0 46px;
		border-top: 1px solid var(--ds-line);
		color: var(--ds-ink-muted);
		font-size: 0.86rem;
	}

	.public-footer p {
		margin: 0;
	}

	@media (max-width: 940px) {
		.holding-hero,
		.overview-section,
		.state-panel,
		.collaboration-card {
			grid-template-columns: 1fr;
		}

		.holding-hero {
			min-height: auto;
		}

		h1 {
			max-width: 10ch;
		}
	}

	@media (max-width: 620px) {
		.holding-hero {
			gap: 34px;
			padding-top: 22px;
		}

		h1 {
			max-width: 100%;
			font-size: clamp(2.65rem, 13.2vw, 4.4rem);
			line-height: 0.94;
		}

		.actions,
		.public-footer {
			flex-direction: column;
		}

		.actions :global(.ds-button) {
			width: 100%;
		}

		.doctrine-band {
			grid-template-columns: 1fr;
			margin-bottom: 74px;
		}

		.overview-section,
		.state-section,
		.signal-section,
		.collaboration-section {
			padding-bottom: 74px;
		}

		.state-panel,
		.collaboration-card {
			padding: 20px;
		}
	}
</style>
