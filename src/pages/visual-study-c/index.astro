---
import "@fontsource/instrument-serif/400.css";
import "@fontsource/ibm-plex-sans/400.css";
import "@fontsource/ibm-plex-sans/500.css";
import "@fontsource/ibm-plex-sans/700.css";
import "@fontsource/source-sans-3/400.css";
import "@fontsource/source-sans-3/500.css";
import "@fontsource/source-sans-3/700.css";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
---

<!doctype html>
<html lang="en" data-theme="open-signal">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Mythadis visual study C, The Open Signal: a light architectural research direction for collective intelligence."
		/>
		<meta name="robots" content="noindex, nofollow" />
		<title>Mythadis Visual Study C | The Open Signal</title>
	</head>
	<body>
		<div class="open-page">
			<header class="open-header" aria-label="Primary">
				<a class="brand" href="/visual-studies/" aria-label="Mythadis visual studies">
					<span class="brand-mark" aria-hidden="true"></span>
					<span>
						<strong>Mythadis</strong>
						<small>The Open Signal</small>
					</span>
				</a>
				<nav class="open-nav" aria-label="Study sections">
					<a href="#signal">Signal</a>
					<a href="#doctrine">Doctrine</a>
					<a href="#surfaces">System</a>
					<a href="/visual-studies/">Compare</a>
				</nav>
				<p class="state">Private research</p>
			</header>

			<main>
				<section class="hero" id="signal" aria-labelledby="page-title">
					<div class="hero-copy">
						<p class="study-label">Visual Study C / The Open Signal</p>
						<h1 id="page-title">Collective intelligence made visible.</h1>
						<p class="mission">
							How do we organize intelligence&mdash;human and artificial&mdash;so that together
							we can solve problems that neither could solve alone?
						</p>
						<p class="supporting-line">
							Many minds. Many machines. Many models. One proof-first fabric.
						</p>
						<div class="actions" aria-label="Primary study actions">
							<a class="button primary" href="#doctrine">Read doctrine</a>
							<a class="button secondary" href="#surfaces">Inspect system</a>
						</div>
					</div>

					<aside class="signal-board" aria-label="Open Signal relationship diagram">
						<div class="board-meta">
							<span>Public research sheet</span>
							<span>OS-03</span>
						</div>
						<svg viewBox="0 0 720 560" role="img" aria-labelledby="signal-title signal-desc">
							<title id="signal-title">Open Signal diagram</title>
							<desc id="signal-desc">
								A light architectural diagram showing people, evidence, institutions, nature, and machines connected by purpose.
							</desc>
							<defs>
								<pattern id="paperGrid" width="40" height="40" patternUnits="userSpaceOnUse">
									<path d="M40 0H0V40" fill="none" stroke="#d7d9d4" stroke-width="1" />
								</pattern>
							</defs>
							<rect x="34" y="34" width="652" height="492" rx="2" class="paper-field" />
							<rect x="34" y="34" width="652" height="492" fill="url(#paperGrid)" opacity=".72" />
							<path class="signal-path human" d="M112 382 C170 284 242 244 332 280 S472 322 604 164" />
							<path class="signal-path evidence" d="M118 154 C226 196 278 142 374 184 S480 270 596 252" />
							<path class="signal-path purpose" d="M172 452 L286 356 L386 412 L514 302 L618 340" />
							<g class="nodes">
								<circle cx="112" cy="382" r="18" />
								<circle cx="332" cy="280" r="18" />
								<circle cx="604" cy="164" r="18" />
								<circle cx="118" cy="154" r="14" />
								<circle cx="374" cy="184" r="14" />
								<circle cx="596" cy="252" r="14" />
								<circle cx="286" cy="356" r="10" />
								<circle cx="514" cy="302" r="10" />
							</g>
							<g class="anchors">
								<path d="M84 118H222" />
								<path d="M84 136H176" />
								<path d="M438 430H626" />
								<path d="M496 448H626" />
								<path d="M396 96V216" />
								<path d="M420 96V164" />
							</g>
							<g class="labels">
								<text x="84" y="96">HUMAN KNOWLEDGE</text>
								<text x="424" y="92">MACHINE REASONING</text>
								<text x="438" y="416">INSTITUTIONAL MEMORY</text>
								<text x="84" y="486">SHARED PURPOSE</text>
							</g>
						</svg>
						<div class="board-footer">
							<span>Relationship field</span>
							<span>Evidence before legend</span>
						</div>
					</aside>
				</section>

				<section class="product-line" aria-label="Product description">
					<p>Mythadis exists to coordinate intelligence&mdash;not just computation.</p>
				</section>

				<section class="doctrine-section" id="doctrine" aria-labelledby="doctrine-title">
					<div class="section-heading">
						<p class="study-label">Core doctrine</p>
						<h2 id="doctrine-title">A civic architecture for proof-first coordination.</h2>
					</div>

					<div class="doctrine-grid">
						<article class="manifesto-card">
							<p class="card-label">Governing phrase</p>
							<h3>Unity without centralization.</h3>
							<p>
								The Open Signal treats intelligence as a relationship between people,
								evidence, institutions, nature, and machines, not as a single black box.
							</p>
						</article>
						<article class="proof-card">
							<p class="card-label">Proof doctrine</p>
							<h3>Evidence before legend.</h3>
							<p>
								Claims become durable when they are visible, inspectable, and connected to
								shared purpose.
							</p>
						</article>
						<article class="status-card">
							<p class="card-label">Current status</p>
							<h3>Mythadis Swarm is currently private research and engineering.</h3>
							<ul>
								<li>Not production-ready</li>
								<li>Not yet a public volunteer network</li>
								<li>Mythadis Agent is not publicly available</li>
							</ul>
						</article>
					</div>
				</section>

				<section class="system-section" id="surfaces" aria-labelledby="surfaces-title">
					<div class="section-heading">
						<p class="study-label">Interface primitives</p>
						<h2 id="surfaces-title">Tactile surfaces for a human technical institution.</h2>
					</div>

					<div class="surface-list">
						<article class="surface-item">
							<span class="item-number">01</span>
							<div>
								<span class="status-pill">Prototype</span>
								<h3>Public Research Record</h3>
								<p>Editorial surfaces for mission notes, long-form reasoning, and institutional memory.</p>
							</div>
						</article>
						<article class="surface-item">
							<span class="item-number">02</span>
							<div>
								<span class="status-pill cyan">Review</span>
								<h3>Relationship Signal</h3>
								<p>Graphic language for connections between humans, models, evidence, and purpose.</p>
							</div>
						</article>
						<article class="surface-item">
							<span class="item-number">03</span>
							<div>
								<span class="status-pill violet">Stable token</span>
								<h3>Coordination Charter</h3>
								<p>A grounded component style for institutional and investor-facing research content.</p>
							</div>
						</article>
					</div>
				</section>
			</main>

			<footer class="open-footer">
				<div>
					<strong>Mythadis Labs</strong>
					<p>Visual Study C: The Open Signal. Built for controlled founder review.</p>
				</div>
				<a href="/visual-studies/">Compare all studies</a>
			</footer>
		</div>
	</body>
</html>

<style>
	:root[data-theme="open-signal"] {
		--font-philosophy: "Instrument Serif", Georgia, serif;
		--font-interface: "IBM Plex Sans", "Manrope", system-ui, sans-serif;
		--font-body: "Source Sans 3", "Inter", system-ui, sans-serif;
		--font-mono: "IBM Plex Mono", "SFMono-Regular", Consolas, monospace;
		--open-canvas: #f3f1ea;
		--open-surface: #fafaf7;
		--open-paper: #ebe8df;
		--open-graphite: #131820;
		--open-slate: #56616c;
		--open-muted: #7d868d;
		--open-rule: #d7d9d4;
		--open-rule-strong: #bfc4c2;
		--open-blue: #176fe8;
		--open-cyan: #21aeb8;
		--open-violet: #6659d9;
		--open-human: #d46c4c;
		--open-proof-gold: #a98642;
		--open-warning: #bd7a35;
		--open-critical: #bd5656;
		--open-dark-section: #111922;
		--open-dark-section-text: #f1f3ee;
		--max-page: 1240px;
		color-scheme: light;
	}

	* {
		box-sizing: border-box;
	}

	html {
		scroll-behavior: smooth;
	}

	body {
		margin: 0;
		min-width: 320px;
		overflow-x: hidden;
		font-family: var(--font-body);
		color: var(--open-graphite);
		background:
			linear-gradient(rgba(19, 24, 32, 0.045) 1px, transparent 1px),
			linear-gradient(90deg, rgba(19, 24, 32, 0.04) 1px, transparent 1px),
			radial-gradient(circle at 12% 12%, rgba(212, 108, 76, 0.15), transparent 28rem),
			radial-gradient(circle at 86% 8%, rgba(33, 174, 184, 0.12), transparent 30rem),
			var(--open-canvas);
		background-size: 64px 64px, 64px 64px, auto, auto, auto;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.open-page {
		width: min(100% - 32px, var(--max-page));
		margin: 0 auto;
	}

	.open-header {
		display: grid;
		grid-template-columns: 1fr auto auto;
		gap: 28px;
		align-items: center;
		min-height: 86px;
		border-bottom: 1px solid var(--open-rule-strong);
	}

	.brand,
	.open-nav,
	.button,
	h2,
	h3 {
		font-family: var(--font-interface);
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 14px;
	}

	.brand strong,
	.brand small {
		display: block;
	}

	.brand small {
		margin-top: 2px;
		color: var(--open-muted);
		font-family: var(--font-mono);
		font-size: 0.66rem;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.brand-mark {
		display: block;
		width: 42px;
		height: 42px;
		border: 2px solid var(--open-graphite);
		background:
			linear-gradient(90deg, transparent 46%, var(--open-graphite) 47% 53%, transparent 54%),
			linear-gradient(transparent 46%, var(--open-graphite) 47% 53%, transparent 54%),
			linear-gradient(135deg, var(--open-surface) 0 58%, var(--open-human) 58% 72%, var(--open-cyan) 72%);
	}

	.open-nav {
		display: flex;
		gap: 24px;
		color: var(--open-slate);
		font-size: 0.94rem;
		font-weight: 500;
	}

	.open-nav a {
		padding-block: 10px;
		border-bottom: 2px solid transparent;
	}

	.open-nav a:hover,
	.open-nav a:focus-visible {
		color: var(--open-graphite);
		border-color: var(--open-blue);
	}

	.state,
	.study-label,
	.card-label,
	.status-pill,
	.item-number,
	.board-meta,
	.board-footer,
	.labels text {
		font-family: var(--font-mono);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.state {
		margin: 0;
		padding: 8px 10px;
		border: 1px solid var(--open-proof-gold);
		color: var(--open-graphite);
		background: rgba(169, 134, 66, 0.14);
		font-size: 0.68rem;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 0.86fr) minmax(440px, 1fr);
		gap: 34px;
		align-items: center;
		min-height: calc(100svh - 86px);
		padding: 56px 0 86px;
	}

	.hero-copy,
	.signal-board {
		min-width: 0;
	}

	.study-label,
	.card-label {
		margin: 0 0 16px;
		color: var(--open-blue);
		font-size: 0.72rem;
	}

	h1,
	h2,
	h3,
	p {
		text-wrap: pretty;
	}

	h1,
	h2,
	h3 {
		margin: 0;
		letter-spacing: 0;
	}

	h1 {
		max-width: 8.7ch;
		font-family: var(--font-interface);
		font-size: clamp(3.6rem, 6.2vw, 5.7rem);
		line-height: 0.9;
	}

	.mission {
		max-width: 720px;
		margin: 30px 0 0;
		font-family: var(--font-philosophy);
		font-size: clamp(1.55rem, 2.7vw, 2.15rem);
		line-height: 1.18;
	}

	.supporting-line {
		max-width: 610px;
		margin: 18px 0 0;
		color: var(--open-slate);
		font-size: 1.08rem;
		line-height: 1.55;
	}

	.actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 34px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 46px;
		padding: 0 18px;
		border: 2px solid var(--open-graphite);
		font-weight: 700;
	}

	.button.primary {
		color: var(--open-surface);
		background: var(--open-graphite);
	}

	.button.secondary {
		color: var(--open-graphite);
		background: var(--open-surface);
	}

	.signal-board {
		border: 1px solid var(--open-rule-strong);
		background: var(--open-surface);
		box-shadow: 0 24px 60px rgba(19, 24, 32, 0.1);
	}

	.board-meta,
	.board-footer {
		display: flex;
		justify-content: space-between;
		gap: 14px;
		padding: 12px 14px;
		color: var(--open-slate);
		font-size: 0.64rem;
	}

	.board-meta {
		border-bottom: 1px solid var(--open-rule);
	}

	.board-footer {
		border-top: 1px solid var(--open-rule);
	}

	svg {
		display: block;
		width: 100%;
		height: auto;
	}

	.paper-field {
		fill: var(--open-paper);
		stroke: var(--open-rule-strong);
	}

	.signal-path {
		fill: none;
		stroke-width: 4;
		stroke-linecap: round;
	}

	.signal-path.human {
		stroke: var(--open-human);
	}

	.signal-path.evidence {
		stroke: var(--open-blue);
	}

	.signal-path.purpose {
		stroke: var(--open-cyan);
	}

	.nodes circle {
		fill: var(--open-surface);
		stroke: var(--open-graphite);
		stroke-width: 3;
	}

	.nodes circle:nth-child(1),
	.nodes circle:nth-child(2),
	.nodes circle:nth-child(3) {
		fill: #ffe1d6;
	}

	.nodes circle:nth-child(4),
	.nodes circle:nth-child(5),
	.nodes circle:nth-child(6) {
		fill: #ddecff;
	}

	.anchors path {
		fill: none;
		stroke: var(--open-slate);
		stroke-width: 2;
	}

	.labels text {
		fill: var(--open-slate);
		font-size: 11px;
	}

	.product-line {
		margin: 0 calc(50% - 50vw);
		padding: 74px max(32px, calc((100vw - var(--max-page)) / 2));
		color: var(--open-dark-section-text);
		background: var(--open-dark-section);
	}

	.product-line p {
		max-width: 980px;
		margin: 0;
		font-family: var(--font-philosophy);
		font-size: clamp(3rem, 7vw, 7rem);
		line-height: 0.94;
	}

	.doctrine-section,
	.system-section {
		padding: 104px 0 0;
	}

	.section-heading {
		display: grid;
		grid-template-columns: 190px minmax(0, 1fr);
		gap: 32px;
		align-items: start;
		margin-bottom: 26px;
	}

	.section-heading h2 {
		max-width: 760px;
		font-size: clamp(2rem, 4vw, 4rem);
		line-height: 1.02;
	}

	.doctrine-grid {
		display: grid;
		grid-template-columns: 1.15fr 0.85fr;
		gap: 16px;
	}

	.manifesto-card,
	.proof-card,
	.status-card,
	.surface-item {
		border: 1px solid var(--open-rule-strong);
		background: var(--open-surface);
	}

	.manifesto-card {
		min-height: 350px;
		padding: 30px;
		background:
			linear-gradient(135deg, rgba(212, 108, 76, 0.14), transparent 44%),
			var(--open-surface);
	}

	.manifesto-card h3 {
		max-width: 10ch;
		font-family: var(--font-philosophy);
		font-size: clamp(3rem, 6vw, 6rem);
		font-weight: 400;
		line-height: 0.9;
	}

	.manifesto-card p:not(.card-label),
	.proof-card p,
	.status-card li,
	.surface-item p {
		color: var(--open-slate);
		font-size: 1.02rem;
		line-height: 1.62;
	}

	.proof-card,
	.status-card {
		padding: 26px;
	}

	.proof-card h3,
	.status-card h3,
	.surface-item h3 {
		font-size: clamp(1.45rem, 2.4vw, 2.2rem);
		line-height: 1.08;
	}

	.status-card {
		grid-column: 1 / -1;
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1fr);
		gap: 28px;
		background: var(--open-paper);
	}

	.status-card ul {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 12px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.status-card li {
		padding: 14px;
		border-top: 4px solid var(--open-proof-gold);
		background: var(--open-surface);
	}

	.surface-list {
		display: grid;
		gap: 14px;
	}

	.surface-item {
		display: grid;
		grid-template-columns: 92px minmax(0, 1fr);
		gap: 28px;
		padding: 24px;
	}

	.item-number {
		color: var(--open-muted);
		font-size: 0.82rem;
	}

	.status-pill {
		display: inline-flex;
		margin-bottom: 14px;
		padding: 5px 8px;
		border: 1px solid rgba(212, 108, 76, 0.46);
		color: var(--open-human);
		background: rgba(212, 108, 76, 0.1);
		font-size: 0.62rem;
	}

	.status-pill.cyan {
		border-color: rgba(33, 174, 184, 0.44);
		color: var(--open-cyan);
		background: rgba(33, 174, 184, 0.1);
	}

	.status-pill.violet {
		border-color: rgba(102, 89, 217, 0.42);
		color: var(--open-violet);
		background: rgba(102, 89, 217, 0.1);
	}

	.open-footer {
		display: flex;
		justify-content: space-between;
		gap: 24px;
		margin-top: 104px;
		padding: 34px 0 48px;
		border-top: 1px solid var(--open-rule-strong);
		color: var(--open-slate);
	}

	.open-footer strong,
	.open-footer a {
		color: var(--open-graphite);
		font-family: var(--font-interface);
		font-weight: 700;
	}

	.open-footer p {
		margin: 6px 0 0;
	}

	@media (max-width: 980px) {
		.open-header,
		.hero,
		.section-heading,
		.doctrine-grid,
		.status-card {
			grid-template-columns: 1fr;
		}

		.open-nav {
			flex-wrap: wrap;
		}

		.hero {
			min-height: auto;
		}

		h1 {
			max-width: 12ch;
		}

		.signal-board {
			max-width: 760px;
		}
	}

	@media (max-width: 640px) {
		.open-page {
			width: min(100% - 22px, var(--max-page));
		}

		.open-header {
			gap: 18px;
			padding: 14px 0;
		}

		.state {
			width: max-content;
		}

		.hero {
			gap: 30px;
			padding: 38px 0 62px;
		}

		h1 {
			max-width: 100%;
			font-size: clamp(2.9rem, 13.6vw, 4.35rem);
			line-height: 0.92;
		}

		.mission {
			font-size: 1.48rem;
		}

		.actions,
		.board-meta,
		.board-footer,
		.open-footer {
			flex-direction: column;
		}

		.button {
			width: 100%;
		}

		.product-line {
			padding-inline: 22px;
		}

		.product-line p {
			font-size: clamp(3rem, 14vw, 4.7rem);
		}

		.status-card ul,
		.surface-item {
			grid-template-columns: 1fr;
		}

		.manifesto-card,
		.proof-card,
		.status-card,
		.surface-item {
			padding: 20px;
		}
	}
</style>
