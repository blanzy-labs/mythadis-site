---
import Button from "../components/design-system/Button.astro";
import SectionLabel from "../components/design-system/SectionLabel.astro";
import SiteHeader from "../components/design-system/SiteHeader.astro";
import StatusLabel from "../components/design-system/StatusLabel.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import {
	fieldReportCategories,
	fieldReportPrinciples,
	fieldReportStatusLabels,
} from "../data/field-reports";

const navItems = [
	{ label: "Vision", href: "/#vision" },
	{ label: "Why Mythadis", href: "/why-mythadis/" },
	{ label: "Proof", href: "/proof/" },
	{ label: "Current State", href: "/current-state/" },
	{ label: "Collaborate", href: "/#collaborate" },
];

const fieldReportPreviews = (await getCollection("field-reports")).sort((a, b) =>
	a.data.number.localeCompare(b.data.number),
);

const getStatusTone = (status: string) => (status === "published" ? "green" : "amber");
const getReportStateLabel = (status: string) =>
	status === "published"
		? "REPORT PUBLISHED"
		: status === "in-review"
			? "REPORT IN REVIEW"
			: "REPORT IN PREPARATION";
---

<BaseLayout
	title="Field Reports — Mythadis"
	description="Field Reports from Mythadis documenting distributed systems, AI coordination, architecture, experiments, evidence, and lessons learned while building the swarm."
	canonicalUrl="https://mythadis.com/field-reports"
>
	<div class="ds-shell field-reports-page">
		<SiteHeader
			items={navItems}
			brandLabel="Mythadis"
			brandSubLabel="Swarm"
			status="Field Reports"
		/>

		<main>
			<section class="reports-hero" aria-labelledby="page-title">
				<StatusLabel tone="blue">Field Reports / Foundations in Development</StatusLabel>
				<h1 id="page-title">Field Reports</h1>
				<p class="hero-statement">Every meaningful step should leave a record.</p>
				<p class="hero-line">Engineering. Research. Architecture. Lessons.</p>
				<p class="hero-intro">
					Field Reports are the public engineering and research journal of Mythadis. They
					document significant decisions, experiments, failures, evidence, and lessons so
					that progress can be examined rather than merely announced.
				</p>
				<div class="hero-actions" aria-label="Field Reports actions">
					<Button href="/proof/">Review the Proof</Button>
					<Button href="/current-state/" variant="secondary">View Current State</Button>
				</div>
			</section>

			<section class="record-section" aria-labelledby="record-title">
				<div class="section-heading">
					<SectionLabel>The Record</SectionLabel>
					<h2 id="record-title">Not a blog. A record of the work.</h2>
				</div>
				<div class="record-copy">
					<p>
						Field Reports will explain how Mythadis systems are designed, tested,
						challenged, and improved.
					</p>
					<p>
						Some reports will document successful experiments. Others will record failed
						approaches, unresolved questions, architectural tradeoffs, or evidence that
						changed the direction of the work.
					</p>
					<p>The goal is not constant publication. The goal is durable understanding.</p>
				</div>
				<div class="principle-list" aria-label="Field Report principles">
					{fieldReportPrinciples.map((principle) => (
						<article>
							<span aria-hidden="true"></span>
							<h3>{principle.name}</h3>
							<p>{principle.body}</p>
						</article>
					))}
				</div>
			</section>

			<section class="first-reports-section" aria-labelledby="first-reports-title">
				<div class="section-heading">
					<SectionLabel>First Reports</SectionLabel>
					<h2 id="first-reports-title">The first records are being prepared.</h2>
				</div>
				<div class="report-previews">
					{fieldReportPreviews.map((report) => (
						<article>
							<div class="report-head">
								<p>{report.data.number}</p>
								<div>
									<span>{report.data.category}</span>
									<StatusLabel tone={getStatusTone(report.data.status)}>
										{fieldReportStatusLabels[report.data.status]}
									</StatusLabel>
								</div>
							</div>
							<h3>
								{report.data.hasPage ? (
									<a href={`/field-reports/${report.data.slug}/`}>{report.data.title}</a>
								) : (
									report.data.title
								)}
							</h3>
							<p class="report-summary">{report.data.summary}</p>
							<div class="preparation-state">{getReportStateLabel(report.data.status)}</div>
							<div class="planned-focus">
								<h4>Planned focus</h4>
								<ul>
									{report.data.plannedFocus.map((focus) => <li>{focus}</li>)}
								</ul>
							</div>
						</article>
					))}
				</div>
			</section>

			<section class="categories-section" aria-labelledby="categories-title">
				<div class="section-heading">
					<SectionLabel>Areas of Inquiry</SectionLabel>
					<h2 id="categories-title">What Field Reports will examine.</h2>
				</div>
				<div class="category-list">
					{fieldReportCategories.map((category) => (
						<article>
							<h3>{category.name}</h3>
							<p>{category.description}</p>
						</article>
					))}
				</div>
			</section>

			<section class="discipline-section" aria-labelledby="discipline-title">
				<div>
					<SectionLabel>Publication Discipline</SectionLabel>
					<h2 id="discipline-title">
						A report is published only when there is something worth preserving.
					</h2>
				</div>
				<div class="discipline-copy">
					<p>
						Field Reports should not exist to satisfy a content schedule. A report should
						be published when the work produces a meaningful decision, experiment, artifact,
						result, limitation, or lesson.
					</p>
					<p>
						Claims must remain connected to the evidence available at the time. Future
						findings may challenge or revise an earlier report, and those changes should
						remain visible.
					</p>
					<p class="evidence-line">Evidence before legend.</p>
				</div>
			</section>

			<section class="final-cta" aria-labelledby="final-title">
				<div>
					<SectionLabel>Continue the Record</SectionLabel>
					<h2 id="final-title">Follow the work as it becomes evidence.</h2>
				</div>
				<div class="final-copy">
					<p>
						Until the first reports are published, the Proof and Current State pages provide
						the clearest record of what Mythadis has demonstrated and what remains under
						development.
					</p>
					<div class="final-actions" aria-label="Field Reports final actions">
						<Button href="/proof/">Review the Proof</Button>
						<Button href="/current-state/" variant="secondary">View Current State</Button>
					</div>
					<a class="collaboration-link" href="https://github.com/blanzy-labs">
						Collaborate with Mythadis →
					</a>
				</div>
			</section>
		</main>

		<footer class="reports-footer">
			<p>Every meaningful step should leave a record.</p>
			<nav aria-label="Field Reports footer navigation">
				<a href="/proof/">Proof</a>
				<a href="/current-state/">Current State</a>
			</nav>
		</footer>
	</div>
</BaseLayout>

<style>
	h1,
	h2,
	h3,
	p {
		text-wrap: pretty;
	}

	h1,
	h2,
	h3 {
		letter-spacing: 0.08em;
	}

	.reports-hero {
		min-height: calc(100svh - 84px);
		display: grid;
		align-content: center;
		padding: 42px 0 92px;
		border-bottom: 1px solid var(--ds-line);
	}

	.reports-hero h1 {
		margin: 26px 0 0;
		font-size: clamp(4.5rem, 11vw, 11.5rem);
		line-height: 0.86;
	}

	.hero-statement,
	.hero-line {
		max-width: 820px;
		margin: 24px 0 0;
		font-family: var(--ds-font-display);
		font-size: clamp(1.8rem, 4vw, 3.8rem);
		font-weight: 700;
		line-height: 0.98;
	}

	.hero-line {
		margin-top: 8px;
		color: var(--ds-mint);
	}

	.hero-intro {
		max-width: 760px;
		margin: 28px 0 0;
		color: var(--ds-ink-soft);
		font-size: 1.08rem;
		line-height: 1.72;
	}

	.hero-actions,
	.final-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 26px;
	}

	.record-section,
	.first-reports-section,
	.categories-section {
		padding: 104px 0;
		border-bottom: 1px solid var(--ds-line);
	}

	.section-heading {
		max-width: 760px;
		margin-bottom: 34px;
	}

	.section-heading h2,
	.discipline-section h2,
	.final-cta h2 {
		margin: 12px 0 0;
		font-family: var(--ds-font-display);
		font-size: clamp(2.35rem, 5.2vw, 5.6rem);
		line-height: 0.96;
	}

	.record-copy {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 24px;
		margin-bottom: 44px;
		color: var(--ds-ink-soft);
		line-height: 1.72;
	}

	.record-copy p {
		margin: 0;
	}

	.principle-list {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		border: 1px solid var(--ds-line);
		background: rgba(255, 255, 255, 0.018);
	}

	.principle-list article {
		min-height: 210px;
		padding: 24px;
		border-right: 1px solid var(--ds-line);
	}

	.principle-list article:last-child {
		border-right: 0;
	}

	.principle-list span {
		display: block;
		width: 18px;
		height: 18px;
		margin-bottom: 38px;
		border: 1px solid var(--ds-line-strong);
		transform: rotate(45deg);
		box-shadow: 0 0 18px rgba(66, 217, 255, 0.18);
	}

	.principle-list h3,
	.category-list h3,
	.report-previews h3 {
		margin: 0;
		font-family: var(--ds-font-display);
		font-size: 1.24rem;
		line-height: 1.05;
	}

	.principle-list p,
	.category-list p {
		margin: 14px 0 0;
		color: var(--ds-ink-soft);
		line-height: 1.62;
	}

	.report-previews {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1px;
		background: var(--ds-line);
		border: 1px solid var(--ds-line);
	}

	.report-previews > article {
		padding: 28px;
		background:
			linear-gradient(145deg, rgba(66, 217, 255, 0.07), transparent 44%),
			rgba(6, 16, 21, 0.94);
	}

	.report-head {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 22px;
		align-items: start;
		margin-bottom: 34px;
	}

	.report-head p {
		margin: 0;
		color: var(--ds-ink);
		font-family: var(--ds-font-mono);
		font-size: clamp(2.2rem, 5vw, 4.8rem);
		line-height: 0.86;
	}

	.report-head div {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 10px;
	}

	.report-head span:not(.ds-status-label) {
		color: var(--ds-blue);
		font-family: var(--ds-font-mono);
		font-size: 0.7rem;
		letter-spacing: 0.08em;
	}

	.report-previews h3 {
		font-size: clamp(1.65rem, 3vw, 2.55rem);
	}

	.report-previews h3 a {
		color: var(--ds-ink);
		border-bottom: 1px solid var(--ds-blue);
	}

	.report-summary {
		max-width: 760px;
		margin: 18px 0 0;
		color: var(--ds-ink-soft);
		line-height: 1.68;
	}

	.preparation-state {
		display: inline-flex;
		margin-top: 26px;
		padding: 8px 10px;
		border: 1px solid var(--ds-line);
		color: var(--ds-amber);
		font-family: var(--ds-font-mono);
		font-size: 0.68rem;
		letter-spacing: 0.08em;
	}

	.planned-focus {
		margin-top: 32px;
		padding-top: 22px;
		border-top: 1px solid var(--ds-line);
	}

	.planned-focus h4 {
		margin: 0 0 14px;
		color: var(--ds-ink-muted);
		font-family: var(--ds-font-mono);
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.planned-focus ul {
		display: grid;
		gap: 10px;
		margin: 0;
		padding: 0;
		list-style: none;
		color: var(--ds-ink-soft);
	}

	.planned-focus li {
		position: relative;
		padding-left: 18px;
		line-height: 1.45;
	}

	.planned-focus li::before {
		content: "";
		position: absolute;
		top: 0.62em;
		left: 0;
		width: 6px;
		height: 6px;
		border: 1px solid var(--ds-blue);
		transform: rotate(45deg);
	}

	.category-list {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		border-top: 1px solid var(--ds-line);
		border-left: 1px solid var(--ds-line);
	}

	.category-list article {
		min-height: 190px;
		padding: 24px;
		border-right: 1px solid var(--ds-line);
		border-bottom: 1px solid var(--ds-line);
		background: rgba(255, 255, 255, 0.018);
	}

	.discipline-section,
	.final-cta {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(320px, 0.82fr);
		gap: 60px;
		padding: 104px 0;
		border-bottom: 1px solid var(--ds-line);
	}

	.discipline-copy,
	.final-copy {
		color: var(--ds-ink-soft);
		line-height: 1.72;
	}

	.discipline-copy p,
	.final-copy p {
		margin-top: 0;
	}

	.evidence-line {
		margin: 28px 0 0;
		color: var(--ds-mint);
		font-family: var(--ds-font-display);
		font-size: clamp(1.75rem, 3vw, 3rem);
		font-weight: 700;
		line-height: 1;
	}

	.collaboration-link {
		display: inline-flex;
		margin-top: 22px;
		color: var(--ds-ink);
		font-family: var(--ds-font-display);
		font-weight: 700;
		border-bottom: 1px solid var(--ds-blue);
	}

	.reports-footer {
		display: flex;
		justify-content: space-between;
		gap: 20px;
		padding: 34px 0 46px;
		border-top: 1px solid var(--ds-line);
		color: var(--ds-ink-muted);
		font-size: 0.86rem;
	}

	.reports-footer p {
		margin: 0;
	}

	.reports-footer nav {
		display: flex;
		flex-wrap: wrap;
		gap: 18px;
	}

	.reports-footer a {
		color: var(--ds-ink-soft);
		border-bottom: 1px solid var(--ds-line-strong);
	}

	@media (max-width: 1040px) {
		.record-copy,
		.category-list {
			grid-template-columns: repeat(2, 1fr);
		}

		.principle-list {
			grid-template-columns: repeat(2, 1fr);
		}

		.principle-list article {
			border-bottom: 1px solid var(--ds-line);
		}

		.principle-list article:nth-child(2n) {
			border-right: 0;
		}
	}

	@media (max-width: 760px) {
		.reports-hero {
			min-height: auto;
			padding: 42px 0 84px;
		}

		.reports-hero h1 {
			font-size: clamp(3.35rem, 18vw, 5.9rem);
			line-height: 0.9;
		}

		.hero-statement,
		.hero-line {
			font-size: clamp(1.45rem, 7.5vw, 2.5rem);
		}

		.hero-actions,
		.final-actions,
		.reports-footer {
			flex-direction: column;
		}

		.hero-actions :global(.ds-button),
		.final-actions :global(.ds-button) {
			width: 100%;
		}

		.record-section,
		.first-reports-section,
		.categories-section,
		.discipline-section,
		.final-cta {
			padding: 76px 0;
		}

		.record-copy,
		.principle-list,
		.report-previews,
		.category-list,
		.discipline-section,
		.final-cta {
			grid-template-columns: 1fr;
		}

		.principle-list article,
		.principle-list article:nth-child(2n) {
			min-height: auto;
			border-right: 0;
		}

		.principle-list article:last-child {
			border-bottom: 0;
		}

		.report-previews > article {
			padding: 24px 20px;
		}

		.report-head {
			grid-template-columns: 1fr;
			gap: 16px;
		}

		.report-head div {
			justify-content: flex-start;
		}

		.category-list article {
			min-height: auto;
		}
	}
</style>
