---
import "@fontsource/manrope/400.css";
import "@fontsource/manrope/500.css";
import "@fontsource/manrope/700.css";
import "@fontsource/source-sans-3/400.css";
import "@fontsource/source-sans-3/500.css";
import "@fontsource/ibm-plex-mono/400.css";
import "@fontsource/ibm-plex-mono/500.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Compare Mythadis visual foundation studies: The Luminous Archive, The Living Atlas, and The Open Signal."
		/>
		<meta name="robots" content="noindex, nofollow" />
		<title>Mythadis Visual Studies</title>
	</head>
	<body>
		<main class="comparison-shell">
			<header class="comparison-header">
				<p class="kicker">Mythadis visual foundation</p>
				<h1>Compare the first three website studies.</h1>
				<p>
					This is a controlled review surface for comparing approved Mythadis messaging
					across three distinct visual philosophies. No study is the production homepage.
				</p>
				<div class="approval-notice">
					<p class="approval-notice__label">Approved direction</p>
					<strong class="approval-notice__title">Study A is selected.</strong>
					<span class="approval-notice__copy">
						Studies B and C are archived alternatives. Production components now derive
						from The Luminous Archive.
					</span>
					<a class="approval-notice__link" href="/design-system/">Review approved design system</a>
				</div>
			</header>

			<section class="study-grid" aria-label="Available visual studies">
				<article class="study-card archive">
					<p class="study-code">Study A / MWEB-003A</p>
					<h2>The Luminous Archive</h2>
					<p>
						Near-black field, electric edge illumination, cinematic archive atmosphere,
						and engineered visual surfaces.
					</p>
					<a href="/visual-study-a/">Review Study A</a>
				</article>

				<article class="study-card atlas">
					<p class="study-code">Study B / MWEB-003B</p>
					<h2>The Living Atlas</h2>
					<p>
						Mineral navy field, editorial structure, map and annotation language,
						and technical-catalog surfaces.
					</p>
					<a href="/visual-study-b/">Review Study B</a>
				</article>

				<article class="study-card open">
					<p class="study-code">Study C / MWEB-003C</p>
					<h2>The Open Signal</h2>
					<p>
						Light mineral canvas, architectural composition, human-centered signal
						graphics, and bold civic research publication energy.
					</p>
					<a href="/visual-study-c/">Review Study C</a>
				</article>
			</section>

			<section class="status-note" aria-label="Current product status">
				<p>Current status</p>
				<ul>
					<li>Mythadis Swarm is private research and engineering.</li>
					<li>It is not production-ready or a public volunteer network.</li>
					<li>The Mythadis Agent is not publicly available.</li>
				</ul>
			</section>
		</main>
	</body>
</html>

<style>
	:root {
		--font-display: "Manrope", system-ui, sans-serif;
		--font-body: "Source Sans 3", "Inter", system-ui, sans-serif;
		--font-mono: "IBM Plex Mono", "SFMono-Regular", Consolas, monospace;
		--bg: #08111a;
		--surface: #101d2a;
		--surface-2: #142636;
		--text: #f1f3ee;
		--muted: #aebbc3;
		--rule: rgba(187, 198, 204, 0.2);
		--cyan: #5ed6d1;
		--blue: #4c9eff;
		--gold: #c4a46a;
		--paper: #f3f1ea;
		--graphite: #131820;
		--human: #d46c4c;
		color-scheme: dark;
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		min-width: 320px;
		font-family: var(--font-body);
		color: var(--text);
		background:
			linear-gradient(rgba(187, 198, 204, 0.045) 1px, transparent 1px),
			linear-gradient(90deg, rgba(187, 198, 204, 0.035) 1px, transparent 1px),
			radial-gradient(circle at 20% 18%, rgba(94, 214, 209, 0.12), transparent 30rem),
			radial-gradient(circle at 82% 20%, rgba(76, 158, 255, 0.12), transparent 30rem),
			var(--bg);
		background-size: 60px 60px, 60px 60px, auto, auto, auto;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.comparison-shell {
		width: min(100% - 32px, 1160px);
		margin: 0 auto;
		padding: 78px 0;
	}

	.comparison-header {
		max-width: 780px;
	}

	.kicker,
	.study-code,
	.status-note > p {
		margin: 0 0 14px;
		font-family: var(--font-mono);
		color: var(--cyan);
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	h1,
	h2,
	p {
		text-wrap: pretty;
	}

	h1,
	h2 {
		margin: 0;
		font-family: var(--font-display);
		letter-spacing: 0;
	}

	h1 {
		font-size: clamp(3rem, 7vw, 6.8rem);
		line-height: 0.95;
	}

	.comparison-header > p:not(.kicker) {
		max-width: 680px;
		margin: 24px 0 0;
		color: var(--muted);
		font-size: 1.18rem;
		line-height: 1.58;
	}

	.study-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 16px;
		margin-top: 56px;
	}

	.study-card {
		min-height: 360px;
		padding: 28px;
		border: 1px solid var(--rule);
		background: var(--surface);
	}

	.study-card.archive {
		background:
			linear-gradient(135deg, rgba(66, 217, 255, 0.15), transparent 46%),
			#061014;
	}

	.study-card.atlas {
		background:
			linear-gradient(135deg, rgba(196, 164, 106, 0.12), transparent 42%),
			var(--surface-2);
	}

	.study-card.open {
		color: var(--graphite);
		background:
			linear-gradient(135deg, rgba(212, 108, 76, 0.16), transparent 42%),
			var(--paper);
	}

	.study-card h2 {
		max-width: 10ch;
		font-size: clamp(2rem, 3.2vw, 3.45rem);
		line-height: 1;
	}

	.study-card p:not(.study-code) {
		max-width: 500px;
		margin: 22px 0 0;
		color: var(--muted);
		font-size: 1rem;
		line-height: 1.6;
	}

	.study-card a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		margin-top: 30px;
		padding: 0 16px;
		border: 1px solid rgba(187, 198, 204, 0.34);
		font-family: var(--font-display);
		font-weight: 700;
	}

	.archive a {
		color: #061014;
		background: linear-gradient(135deg, #f1fbff, #7ee9dd);
	}

	.atlas a {
		color: #061014;
		background: var(--cyan);
	}

	.open .study-code {
		color: #176fe8;
	}

	.open p:not(.study-code) {
		color: #56616c;
	}

	.open a {
		color: #fafaf7;
		background: var(--graphite);
		border-color: var(--graphite);
	}

	.status-note {
		margin-top: 18px;
		padding: 22px;
		border: 1px solid rgba(196, 164, 106, 0.32);
		background: rgba(196, 164, 106, 0.07);
	}

	.status-note ul {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 12px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.status-note li {
		color: var(--muted);
		line-height: 1.5;
	}

	.approval-notice {
		display: grid;
		gap: 8px;
		margin-top: 28px;
		padding: 18px;
		border: 1px solid rgba(246, 197, 107, 0.34);
		background: rgba(246, 197, 107, 0.08);
	}

	.approval-notice__label {
		margin: 0 0 10px;
		color: var(--gold);
		font-family: var(--font-mono);
		font-size: 0.68rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.approval-notice__title {
		font-family: var(--font-display);
		font-size: 1.2rem;
	}

	.approval-notice__copy {
		max-width: 620px;
		color: var(--muted);
		line-height: 1.5;
	}

	.approval-notice__link {
		width: max-content;
		margin-top: 6px;
		color: #061014;
		padding: 10px 12px;
		background: linear-gradient(135deg, #f1fbff, #7ee9dd);
		font-family: var(--font-display);
		font-weight: 700;
	}

	@media (max-width: 980px) {
		.study-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 780px) {
		.comparison-shell {
			width: min(100% - 22px, 1160px);
			padding: 42px 0;
		}

		.status-note ul {
			grid-template-columns: 1fr;
		}

		h1 {
			font-size: clamp(2.8rem, 15vw, 4.4rem);
		}
	}
</style>
