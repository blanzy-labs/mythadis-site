---
import StatusLabel from "./StatusLabel.astro";

interface Props {
	title: string;
	status: string;
	tone?: "blue" | "amber" | "green" | "plum";
}

const { title, status, tone = "blue" } = Astro.props;
---

<article class="ds-system-card">
	<StatusLabel tone={tone}>{status}</StatusLabel>
	<h3>{title}</h3>
	<p><slot /></p>
</article>

<style>
	.ds-system-card {
		min-height: 260px;
		padding: 24px;
		border: 1px solid var(--ds-line);
		background: var(--ds-surface);
		box-shadow: 0 18px 54px rgba(0, 0, 0, 0.2);
	}

	.ds-system-card :global(.ds-status-label) {
		margin-bottom: 36px;
	}

	.ds-system-card h3 {
		margin: 0;
		font-size: clamp(1.35rem, 2.2vw, 2rem);
		line-height: 1.04;
	}

	.ds-system-card p {
		margin: 16px 0 0;
		color: var(--ds-ink-soft);
		font-size: 0.98rem;
		line-height: 1.62;
	}
</style>
