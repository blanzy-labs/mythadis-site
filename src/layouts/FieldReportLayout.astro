---
import type { CollectionEntry } from "astro:content";
import Button from "../components/design-system/Button.astro";
import SectionLabel from "../components/design-system/SectionLabel.astro";
import SiteHeader from "../components/design-system/SiteHeader.astro";
import StatusLabel from "../components/design-system/StatusLabel.astro";
import BaseLayout from "./BaseLayout.astro";
import { fieldReportStatusLabels } from "../data/field-reports";

interface Props {
	report: CollectionEntry<"field-reports">;
}

const { report } = Astro.props;
const { data } = report;
const isPublished = data.status === "published";
const canonicalUrl = `https://mythadis.com/field-reports/${data.slug}`;

const navItems = [
	{ label: "Vision", href: "/#vision" },
	{ label: "Why Mythadis", href: "/why-mythadis/" },
	{ label: "Proof", href: "/proof/" },
	{ label: "Current State", href: "/current-state/" },
	{ label: "Collaborate", href: "/#collaborate" },
];
---

<BaseLayout
	title={`${data.title} — Mythadis Field Reports`}
	description={data.description}
	canonicalUrl={canonicalUrl}
	noindex={!isPublished}
>
	<div class="ds-shell field-report-page">
		<SiteHeader
			items={navItems}
			brandLabel="Mythadis"
			brandSubLabel="Swarm"
			status="Field Report"
		/>

		<main>
			<section class="report-hero" aria-labelledby="page-title">
				<div class="report-kicker">
					<StatusLabel tone={isPublished ? "green" : "amber"}>
						{fieldReportStatusLabels[data.status]}
					</StatusLabel>
					<span>{data.category}</span>
				</div>
				<p class="report-number">Field Report {data.number}</p>
				<h1 id="page-title">{data.title}</h1>
				<p class="report-summary">{data.summary}</p>
				<div class="report-meta" aria-label="Report metadata">
					<span>STATUS / {fieldReportStatusLabels[data.status]}</span>
					{data.publicationDate ? <span>PUBLISHED / {data.publicationDate}</span> : <span>PUBLICATION DATE / PENDING FOUNDER APPROVAL</span>}
					<span>CANONICAL / {canonicalUrl}</span>
				</div>
			</section>

			<section class="report-context" aria-labelledby="context-title">
				<div>
					<SectionLabel>Report Frame</SectionLabel>
					<h2 id="context-title">
						{isPublished ? "A founding doctrine." : "A doctrine under review."}
					</h2>
				</div>
				<div class="context-copy">
					{isPublished ? (
						<>
							<p>
								This report records one of the core Mythadis doctrines: shared purpose
								should not require total ownership by a single company, institution,
								government, or AI system.
							</p>
							<p>
								It is published as a public reference for engineering, research,
								institutional, and partner conversations.
							</p>
						</>
					) : (
						<>
							<p>
								This report is available for founder copy and visual review. It is not yet
								marked as published in production.
							</p>
							<p>
								The purpose of this review state is to inspect the argument, the claim
								boundaries, and the page experience before a publication date is recorded.
							</p>
						</>
					)}
				</div>
			</section>

			<article class="report-body">
				<slot />
			</article>

			<section class="report-close" aria-labelledby="continue-title">
				<div>
					<SectionLabel>Continue the Record</SectionLabel>
					<h2 id="continue-title">Follow the proof behind the doctrine.</h2>
				</div>
				<div class="close-actions">
					<Button href="/field-reports/">Field Reports</Button>
					<Button href="/proof/" variant="secondary">Review the Proof</Button>
					<Button href="/current-state/" variant="secondary">View Current State</Button>
				</div>
			</section>
		</main>

		<footer class="report-footer">
			<p>Evidence before legend.</p>
			<nav aria-label="Report footer navigation">
				<a href="/field-reports/">Field Reports</a>
				<a href="/proof/">Proof</a>
				<a href="/current-state/">Current State</a>
			</nav>
		</footer>
	</div>
</BaseLayout>

<style>
	.field-report-page h1,
	.field-report-page h2,
	.field-report-page h3,
	.field-report-page p {
		text-wrap: pretty;
	}

	.report-hero {
		min-height: calc(92svh - 84px);
		display: grid;
		align-content: center;
		padding: 42px 0 86px;
		border-bottom: 1px solid var(--ds-line);
	}

	.report-kicker {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 12px;
	}

	.report-kicker > span:not(.ds-status-label) {
		color: var(--ds-blue);
		font-family: var(--ds-font-mono);
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.report-number {
		margin: 34px 0 0;
		color: var(--ds-mint);
		font-family: var(--ds-font-mono);
		font-size: 0.82rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.report-hero h1 {
		max-width: 1060px;
		margin: 16px 0 0;
		font-family: var(--ds-font-display);
		font-size: clamp(3.5rem, 9.8vw, 9.8rem);
		line-height: 0.9;
		letter-spacing: 0.08em;
	}

	.report-summary {
		max-width: 820px;
		margin: 28px 0 0;
		color: var(--ds-ink-soft);
		font-size: clamp(1.18rem, 2vw, 1.62rem);
		line-height: 1.55;
	}

	.report-meta {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 1px;
		max-width: 980px;
		margin-top: 42px;
		background: var(--ds-line);
		border: 1px solid var(--ds-line);
	}

	.report-meta span {
		padding: 14px;
		color: var(--ds-ink-muted);
		background: rgba(5, 15, 20, 0.92);
		font-family: var(--ds-font-mono);
		font-size: 0.66rem;
		line-height: 1.45;
		letter-spacing: 0.08em;
		overflow-wrap: anywhere;
	}

	.report-context,
	.report-close {
		display: grid;
		grid-template-columns: minmax(0, 0.9fr) minmax(320px, 1fr);
		gap: 60px;
		padding: 78px 0;
		border-bottom: 1px solid var(--ds-line);
	}

	.report-context h2,
	.report-close h2 {
		margin: 12px 0 0;
		font-family: var(--ds-font-display);
		font-size: clamp(2.2rem, 5vw, 5.2rem);
		line-height: 0.96;
		letter-spacing: 0.08em;
	}

	.context-copy {
		color: var(--ds-ink-soft);
		line-height: 1.75;
	}

	.context-copy p {
		margin: 0 0 18px;
	}

	.report-body {
		max-width: 820px;
		margin: 0 auto;
		padding: 86px 0;
		color: var(--ds-ink-soft);
		font-size: 1.08rem;
		line-height: 1.82;
	}

	.report-body :global(h2) {
		margin: 72px 0 18px;
		color: var(--ds-ink);
		font-family: var(--ds-font-display);
		font-size: clamp(2rem, 4.2vw, 4.4rem);
		line-height: 1;
		letter-spacing: 0.08em;
	}

	.report-body :global(h2:first-child) {
		margin-top: 0;
	}

	.report-body :global(p) {
		margin: 0 0 24px;
	}

	.report-body :global(strong) {
		color: var(--ds-mint);
	}

	.report-body :global(ul) {
		display: grid;
		gap: 12px;
		margin: 28px 0;
		padding: 0;
		list-style: none;
	}

	.report-body :global(li) {
		position: relative;
		padding-left: 22px;
	}

	.report-body :global(li::before) {
		content: "";
		position: absolute;
		top: 0.78em;
		left: 0;
		width: 7px;
		height: 7px;
		border: 1px solid var(--ds-blue);
		transform: rotate(45deg);
	}

	.report-close {
		align-items: end;
	}

	.close-actions {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 12px;
	}

	.report-footer {
		display: flex;
		justify-content: space-between;
		gap: 20px;
		padding: 34px 0 46px;
		border-top: 1px solid var(--ds-line);
		color: var(--ds-ink-muted);
		font-size: 0.86rem;
	}

	.report-footer p {
		margin: 0;
	}

	.report-footer nav {
		display: flex;
		flex-wrap: wrap;
		gap: 18px;
	}

	.report-footer a {
		color: var(--ds-ink-soft);
		border-bottom: 1px solid var(--ds-line-strong);
	}

	@media (max-width: 900px) {
		.report-meta,
		.report-context,
		.report-close {
			grid-template-columns: 1fr;
		}

		.close-actions {
			justify-content: flex-start;
		}
	}

	@media (max-width: 680px) {
		.report-hero {
			min-height: auto;
			padding: 42px 0 78px;
		}

		.report-hero h1 {
			font-size: clamp(2.85rem, 15vw, 5.3rem);
			line-height: 0.94;
		}

		.report-context,
		.report-close {
			padding: 64px 0;
		}

		.report-body {
			padding: 68px 0;
			font-size: 1rem;
		}

		.report-body :global(h2) {
			margin-top: 58px;
		}

		.close-actions,
		.close-actions :global(.ds-button),
		.report-footer {
			flex-direction: column;
			width: 100%;
		}
	}
</style>
