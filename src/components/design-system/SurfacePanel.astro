---
interface Props {
	variant?: "default" | "strong" | "warning";
}

const { variant = "default" } = Astro.props;
---

<div class:list={["ds-surface-panel", `ds-surface-panel--${variant}`]}>
	<slot />
</div>

<style>
	.ds-surface-panel {
		border: 1px solid var(--ds-line);
		background: var(--ds-surface);
		box-shadow: 0 18px 54px rgba(0, 0, 0, 0.2);
	}

	.ds-surface-panel--strong {
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.08), transparent 42%),
			var(--ds-surface-strong);
	}

	.ds-surface-panel--warning {
		border-color: rgba(246, 197, 107, 0.26);
		background: linear-gradient(120deg, rgba(246, 197, 107, 0.075), rgba(10, 22, 28, 0.76));
	}
</style>
