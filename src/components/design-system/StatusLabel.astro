---
interface Props {
	tone?: "blue" | "amber" | "green" | "plum";
}

const { tone = "blue" } = Astro.props;
---

<span class:list={["ds-status-label", `ds-status-label--${tone}`]}>
	<slot />
</span>

<style>
	.ds-status-label {
		display: inline-flex;
		padding: 7px 9px;
		border: 1px solid rgba(66, 217, 255, 0.34);
		color: var(--ds-blue);
		background: rgba(66, 217, 255, 0.08);
		font-family: var(--ds-font-mono);
		font-size: 0.64rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.ds-status-label--amber {
		border-color: rgba(246, 197, 107, 0.36);
		color: var(--ds-amber);
		background: rgba(246, 197, 107, 0.08);
	}

	.ds-status-label--green {
		border-color: rgba(140, 240, 205, 0.36);
		color: var(--ds-mint);
		background: rgba(140, 240, 205, 0.08);
	}

	.ds-status-label--plum {
		border-color: rgba(141, 122, 223, 0.36);
		color: var(--ds-plum);
		background: rgba(141, 122, 223, 0.08);
	}
</style>
