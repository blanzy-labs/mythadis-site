---
const items = [
	"Not production-ready",
	"Not yet a public volunteer network",
	"Mythadis Agent is not publicly available",
];
---

<aside class="ds-current-state">
	<div>
		<p>Current status</p>
		<h3>Mythadis Swarm is currently private research and engineering.</h3>
	</div>
	<ul>
		{items.map((item) => <li>{item}</li>)}
	</ul>
</aside>

<style>
	.ds-current-state {
		display: grid;
		grid-template-columns: minmax(0, 0.72fr) minmax(280px, 1fr);
		gap: 28px;
		align-items: start;
		padding: 26px;
		border: 1px solid rgba(246, 197, 107, 0.26);
		background: linear-gradient(120deg, rgba(246, 197, 107, 0.075), rgba(10, 22, 28, 0.76));
	}

	.ds-current-state p {
		margin: 0 0 16px;
		color: var(--ds-blue);
		font-family: var(--ds-font-mono);
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.ds-current-state h3 {
		margin: 0;
		font-size: clamp(1.35rem, 2.2vw, 2rem);
		line-height: 1.04;
	}

	.ds-current-state ul {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 10px;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.ds-current-state li {
		min-height: 72px;
		padding: 14px;
		border: 1px solid rgba(246, 197, 107, 0.18);
		color: var(--ds-ink-soft);
		background: rgba(2, 7, 10, 0.32);
		line-height: 1.55;
	}

	@media (max-width: 940px) {
		.ds-current-state,
		.ds-current-state ul {
			grid-template-columns: 1fr;
		}
	}
</style>
