---
import Button from "../components/design-system/Button.astro";
import NetworkMotif from "../components/design-system/NetworkMotif.astro";
import SectionLabel from "../components/design-system/SectionLabel.astro";
import SiteHeader from "../components/design-system/SiteHeader.astro";
import StatusLabel from "../components/design-system/StatusLabel.astro";
import SurfacePanel from "../components/design-system/SurfacePanel.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const navItems = [
	{ label: "Vision", href: "#vision" },
	{ label: "Why Mythadis", href: "/why-mythadis/" },
	{ label: "Proof", href: "/proof/" },
	{ label: "Current State", href: "/current-state/" },
	{ label: "Collaborate", href: "#collaborate" },
];

const fragmentationNodes = [
	"Knowledge",
	"Institutions",
	"AI",
	"People",
	"Machines",
	"Evidence",
];

const flowSteps = [
	"Mission",
	"Data Parcels",
	"Discovery",
	"Agents",
	"Evidence",
	"Annals",
];

const missionSwarms = [
	"Longevity",
	"Pollution",
	"Climate",
	"Public Science",
	"Knowledge Preservation",
];

const collaborators = [
	"Engineers",
	"Researchers",
	"Institutions",
	"Advisors",
	"Early testers",
];
---

<BaseLayout
	title="Mythadis | Coordinate Intelligence"
	description="Mythadis exists to coordinate intelligence—not just computation. A proof-first fabric for human and artificial intelligence."
>
	<div class="ds-shell">
		<SiteHeader
			items={navItems}
			brandLabel="Mythadis"
			brandSubLabel="Swarm"
			status="Private R&D"
		/>

		<main>
			<section class="home-hero" id="vision" aria-labelledby="page-title">
				<div class="home-hero__copy">
					<SectionLabel>Mission question</SectionLabel>
					<h1 id="page-title">
						How do we organize intelligence&mdash;human and artificial&mdash;so that together
						we can solve problems that neither could solve alone?
					</h1>
					<p class="hero-answer">Mythadis exists to coordinate intelligence&mdash;not just computation.</p>
					<div class="hero-actions" aria-label="Primary page actions">
						<Button href="#problem">Explore the Vision</Button>
						<Button href="/current-state/" variant="secondary">Current State</Button>
						<Button href="#collaborate" variant="secondary">Collaborate</Button>
					</div>
				</div>
				<div class="home-hero__visual">
					<NetworkMotif />
				</div>
			</section>

			<section class="signal-statement" aria-label="Core system statement">
				<p>Many minds.</p>
				<p>Many machines.</p>
				<p>Many models.</p>
				<p>One proof-first fabric.</p>
			</section>

			<section class="problem-section" id="problem" aria-labelledby="problem-title">
				<div class="section-heading">
					<SectionLabel>Humanity's problem</SectionLabel>
					<h2 id="problem-title">The intelligence we need is fragmented.</h2>
				</div>
				<div class="problem-layout">
					<div class="fragment-map" aria-label="Fragmented systems diagram">
						{fragmentationNodes.map((node, index) => (
							<div class={`fragment-node fragment-node--${index + 1}`}>
								<span>{node}</span>
							</div>
						))}
						<div class="fragment-core">
							<span>Disconnected proof</span>
						</div>
					</div>
					<div class="problem-copy">
						<p>
							Knowledge, institutions, AI, people, and machines are learning in isolation.
						</p>
						<p>
							Mythadis asks what becomes possible when intelligence can discover, coordinate,
							verify, and remember together.
						</p>
					</div>
				</div>
			</section>

			<section class="unity-section" aria-labelledby="unity-title">
				<SectionLabel>Principle</SectionLabel>
				<h2 id="unity-title">Unity without centralization.</h2>
				<p>
					Coordination should increase shared capacity without turning every mind, machine,
					or institution into a subordinate node.
				</p>
			</section>

			<section class="swarm-section" id="swarm" aria-labelledby="swarm-title">
				<div class="section-heading">
					<SectionLabel>What is Mythadis Swarm?</SectionLabel>
					<h2 id="swarm-title">A proof-first fabric for coordinated intelligence.</h2>
				</div>
				<div class="swarm-grid">
					<article>
						<StatusLabel>Coordination</StatusLabel>
						<h3>Not centralization.</h3>
						<p>
							Mythadis Swarm is the flagship coordination platform for aligning many forms of
							intelligence around mission-specific work.
						</p>
					</article>
					<article>
						<StatusLabel tone="green">Plural intelligence</StatusLabel>
						<h3>Human and artificial.</h3>
						<p>
							The system treats people, machines, models, evidence, and archives as participants
							in a larger fabric.
						</p>
					</article>
					<article>
						<StatusLabel tone="amber">Proof-first</StatusLabel>
						<h3>Memory before myth.</h3>
						<p>
							Claims should become durable through recorded evidence, not through momentum,
							status, or spectacle.
						</p>
					</article>
				</div>
			</section>

			<section class="flow-section" aria-labelledby="flow-title">
				<div class="section-heading">
					<SectionLabel>How the Swarm Works</SectionLabel>
					<h2 id="flow-title">A simple path from mission to recorded proof.</h2>
				</div>
				<ol class="flow-list" aria-label="Six-step Mythadis Swarm flow">
					{flowSteps.map((step) => (
						<li>
							<span>{step}</span>
						</li>
					))}
				</ol>
			</section>

			<section class="agent-section" aria-labelledby="agent-title">
				<div>
					<SectionLabel>Mythadis Agent</SectionLabel>
					<h2 id="agent-title">Future participation begins at the edge.</h2>
				</div>
				<SurfacePanel variant="warning">
					<div class="agent-panel">
						<StatusLabel tone="amber">Not currently available</StatusLabel>
						<p>
							The Mythadis Agent is the future participation layer for machines and operators.
							It is not public yet.
						</p>
					</div>
				</SurfacePanel>
			</section>

			<section class="mission-control-section" aria-labelledby="mission-control-title">
				<div class="control-grid">
					<div class="control-copy">
						<SectionLabel>Mission Control</SectionLabel>
						<h2 id="mission-control-title">Coordination, not control.</h2>
						<p>
							Mission Control is the interface for making distributed work legible: what exists,
							what is missing, what has been observed, and what has been proven.
						</p>
					</div>
					<div class="control-panel" aria-label="Mission Control diagram">
						<span>Mission</span>
						<span>Signals</span>
						<span>Relics</span>
						<span>Annals</span>
					</div>
				</div>
			</section>

			<section class="mission-swarms-section" aria-labelledby="mission-swarms-title">
				<div class="section-heading">
					<SectionLabel>Mission Swarms</SectionLabel>
					<h2 id="mission-swarms-title">Future swarms point toward humanity-scale work.</h2>
				</div>
				<div class="mission-card-grid">
					{missionSwarms.map((mission) => (
						<article>
							<span aria-hidden="true"></span>
							<h3>{mission}</h3>
						</article>
					))}
				</div>
			</section>

			<section class="evidence-section" aria-labelledby="evidence-title">
				<SectionLabel>Evidence before legend</SectionLabel>
				<h2 id="evidence-title">Every Epoch has a Gate.</h2>
				<div class="evidence-lines">
					<p>Every Gate requires Relics and Signals.</p>
					<p>Vision is not enough.</p>
					<p>Proof must be recorded.</p>
				</div>
			</section>

			<section class="current-state-section" id="current-state" aria-labelledby="state-title">
				<div class="section-heading">
					<SectionLabel>Current State</SectionLabel>
					<h2 id="state-title">Private R&D. Early prototypes. Future research directions.</h2>
				</div>
				<SurfacePanel variant="warning">
					<div class="state-panel">
						<div>
							<StatusLabel tone="amber">Private R&D · Early multi-node prototype · No public agent</StatusLabel>
							<h3>Mythadis Swarm is currently private research and engineering.</h3>
						</div>
						<div class="state-copy">
							<p>
								Early prototypes are testing peer discovery, communication across heterogeneous
								machines, distributed data storage and recovery, lightweight knowledge discovery,
								archive health, and the foundations of Mission Control.
							</p>
							<p>
								The project is not production-ready. It is not yet a public volunteer network,
								and the Mythadis Agent is not publicly available.
							</p>
							<p>
								The immediate mission is to prove that the fabric works. Larger Mission Swarms
								and humanity-scale outcomes remain future research directions.
							</p>
						</div>
					</div>
				</SurfacePanel>
			</section>

			<section class="collaborate-section" id="collaborate" aria-labelledby="collaborate-title">
				<SurfacePanel variant="strong">
					<div class="collaborate-card">
						<div>
							<SectionLabel>Collaborate</SectionLabel>
							<h2 id="collaborate-title">Help shape the first credible swarm.</h2>
							<p>
								Early conversations are most useful with people who can pressure-test the
								architecture, the proof discipline, and the mission model.
							</p>
						</div>
						<div class="collaborator-list" aria-label="Collaboration audiences">
							{collaborators.map((collaborator) => <span>{collaborator}</span>)}
						</div>
						<div class="contact-panel">
							<p class="contact-label">Contact path</p>
							<a href="https://github.com/blanzy-labs" rel="noreferrer">github.com/blanzy-labs</a>
							<p>
								Use the Blanzy Labs public GitHub presence as the current collaboration path
								while Mythadis remains private R&D.
							</p>
						</div>
					</div>
				</SurfacePanel>
			</section>
		</main>

		<footer class="public-footer">
			<p>Mythadis exists to coordinate intelligence&mdash;not just computation.</p>
			<nav aria-label="Footer navigation">
				<a href="/field-reports/">Field Reports</a>
				<a href="/proof/">Proof</a>
				<a href="/current-state/">Current State</a>
			</nav>
		</footer>
	</div>
</BaseLayout>

<style>
	h1,
	h2,
	h3,
	p {
		text-wrap: pretty;
	}

	h1,
	h2,
	h3 {
		margin: 0;
		font-family: var(--ds-font-display);
		letter-spacing: 0;
	}

	.home-hero {
		display: grid;
		grid-template-columns: minmax(0, 1.05fr) minmax(360px, 0.95fr);
		gap: 48px;
		align-items: center;
		min-height: calc(100svh - 84px);
		padding: 42px 0 86px;
	}

	.home-hero__copy {
		max-width: 860px;
	}

	.home-hero h1 {
		max-width: 14ch;
		font-size: clamp(3.65rem, 7.1vw, 7.4rem);
		line-height: 0.9;
	}

	.hero-answer {
		max-width: 680px;
		margin: 30px 0 0;
		color: var(--ds-ink);
		font-family: var(--ds-font-display);
		font-size: clamp(1.35rem, 2.4vw, 2.2rem);
		font-weight: 700;
		line-height: 1.12;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 34px;
	}

	.signal-statement {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: 0;
		margin: 0 0 118px;
		border-block: 1px solid var(--ds-line);
	}

	.signal-statement p {
		min-height: 148px;
		margin: 0;
		padding: 22px;
		border-right: 1px solid var(--ds-line);
		color: var(--ds-ink);
		font-family: var(--ds-font-display);
		font-size: clamp(1.45rem, 2.6vw, 2.7rem);
		font-weight: 700;
		line-height: 1;
	}

	.signal-statement p:last-child {
		border-right: 0;
		color: var(--ds-mint);
	}

	.problem-section,
	.swarm-section,
	.flow-section,
	.agent-section,
	.mission-control-section,
	.mission-swarms-section,
	.current-state-section,
	.collaborate-section {
		padding: 0 0 118px;
	}

	.section-heading {
		max-width: 900px;
		margin-bottom: 30px;
	}

	.section-heading h2,
	.agent-section h2,
	.control-copy h2,
	.collaborate-card h2 {
		font-size: clamp(2.2rem, 4.6vw, 4.55rem);
		line-height: 0.98;
	}

	.problem-layout,
	.agent-section,
	.control-grid,
	.state-panel,
	.collaborate-card {
		display: grid;
		grid-template-columns: minmax(0, 0.92fr) minmax(320px, 1fr);
		gap: 32px;
		align-items: start;
	}

	.fragment-map {
		position: relative;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 12px;
		min-height: 390px;
		padding: 22px;
		border: 1px solid var(--ds-line-strong);
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.06), transparent 28%),
			radial-gradient(circle at 50% 50%, rgba(66, 217, 255, 0.18), transparent 13rem),
			rgba(2, 7, 10, 0.46);
		overflow: hidden;
	}

	.fragment-map::before,
	.fragment-map::after {
		position: absolute;
		inset: 50% 10%;
		height: 1px;
		content: "";
		background: linear-gradient(90deg, transparent, rgba(66, 217, 255, 0.48), transparent);
	}

	.fragment-map::after {
		transform: rotate(90deg);
	}

	.fragment-node,
	.fragment-core,
	.control-panel span,
	.collaborator-list span {
		border: 1px solid var(--ds-line);
		background: rgba(10, 22, 28, 0.74);
	}

	.fragment-node {
		position: relative;
		z-index: 1;
		display: grid;
		align-items: center;
		min-height: 98px;
		padding: 14px;
		color: var(--ds-ink-soft);
		font-family: var(--ds-font-mono);
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.fragment-node--2,
	.fragment-node--5 {
		transform: translateY(34px);
	}

	.fragment-core {
		position: absolute;
		z-index: 2;
		top: 50%;
		left: 50%;
		display: grid;
		place-items: center;
		width: min(52%, 250px);
		min-height: 86px;
		padding: 16px;
		color: var(--ds-amber);
		font-family: var(--ds-font-display);
		font-weight: 700;
		text-align: center;
		transform: translate(-50%, -50%);
		box-shadow: 0 0 36px rgba(246, 197, 107, 0.12);
	}

	.problem-copy {
		display: grid;
		gap: 18px;
	}

	.problem-copy p,
	.swarm-grid p,
	.agent-panel p,
	.control-copy p,
	.state-copy p,
	.collaborate-card p,
	.contact-panel p {
		margin: 0;
		color: var(--ds-ink-soft);
		font-size: 1rem;
		line-height: 1.68;
	}

	.problem-copy p:first-child {
		color: var(--ds-ink);
		font-family: var(--ds-font-display);
		font-size: clamp(1.55rem, 3vw, 2.45rem);
		font-weight: 700;
		line-height: 1.08;
	}

	.unity-section {
		display: grid;
		align-content: center;
		min-height: 74svh;
		padding: 76px 0 132px;
	}

	.unity-section h2 {
		max-width: 920px;
		font-size: clamp(4.4rem, 11vw, 10.8rem);
		line-height: 0.86;
	}

	.unity-section p {
		max-width: 620px;
		margin: 30px 0 0 auto;
		color: var(--ds-ink-soft);
		font-size: clamp(1.05rem, 1.8vw, 1.28rem);
		line-height: 1.65;
	}

	.swarm-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 18px;
	}

	.swarm-grid article,
	.mission-card-grid article {
		min-height: 292px;
		padding: 24px;
		border: 1px solid var(--ds-line);
		background: var(--ds-surface);
		box-shadow: 0 18px 54px rgba(0, 0, 0, 0.2);
	}

	.swarm-grid h3,
	.mission-card-grid h3 {
		margin-top: 34px;
		font-size: clamp(1.45rem, 2.6vw, 2.3rem);
		line-height: 1.04;
	}

	.swarm-grid p {
		margin-top: 16px;
	}

	.flow-list {
		display: grid;
		grid-template-columns: repeat(6, 1fr);
		gap: 0;
		padding: 0;
		margin: 0;
		list-style: none;
		border: 1px solid var(--ds-line-strong);
		background: rgba(2, 7, 10, 0.36);
	}

	.flow-list li {
		position: relative;
		display: grid;
		align-content: space-between;
		min-height: 210px;
		padding: 20px;
		border-right: 1px solid var(--ds-line);
	}

	.flow-list li:last-child {
		border-right: 0;
	}

	.flow-list li:not(:last-child)::after {
		position: absolute;
		top: 50%;
		right: -9px;
		z-index: 2;
		width: 18px;
		height: 18px;
		content: "";
		border-top: 1px solid var(--ds-blue);
		border-right: 1px solid var(--ds-blue);
		background: var(--ds-void);
		transform: translateY(-50%) rotate(45deg);
	}

	.flow-list li::before {
		color: var(--ds-blue);
		font-family: var(--ds-font-mono);
		font-size: 0.7rem;
		content: "0" counter(list-item);
	}

	.flow-list span {
		font-family: var(--ds-font-display);
		font-size: clamp(1.12rem, 1.7vw, 1.5rem);
		font-weight: 700;
		line-height: 1.05;
	}

	.agent-panel,
	.state-panel,
	.collaborate-card {
		padding: 28px;
	}

	.agent-panel p {
		margin-top: 24px;
		font-family: var(--ds-font-display);
		font-size: clamp(1.45rem, 2.8vw, 2.4rem);
		font-weight: 700;
		line-height: 1.08;
	}

	.control-grid {
		grid-template-columns: minmax(320px, 0.82fr) minmax(0, 1fr);
		align-items: stretch;
	}

	.control-copy p {
		margin-top: 24px;
	}

	.control-panel {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;
		padding: 22px;
		border: 1px solid var(--ds-line-strong);
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.06), transparent 30%),
			rgba(2, 7, 10, 0.48);
	}

	.control-panel span {
		display: grid;
		place-items: center;
		min-height: 142px;
		color: var(--ds-ink);
		font-family: var(--ds-font-display);
		font-size: clamp(1.28rem, 2.4vw, 2rem);
		font-weight: 700;
	}

	.mission-card-grid {
		display: grid;
		grid-template-columns: repeat(5, 1fr);
		gap: 14px;
	}

	.mission-card-grid article {
		position: relative;
		min-height: 220px;
		overflow: hidden;
	}

	.mission-card-grid article::before {
		position: absolute;
		inset: 18px;
		content: "";
		border: 1px solid rgba(189, 238, 255, 0.12);
	}

	.mission-card-grid span {
		display: block;
		width: 36px;
		height: 36px;
		border: 1px solid var(--ds-line-strong);
		background: linear-gradient(135deg, var(--ds-blue), var(--ds-mint));
		box-shadow: 0 0 28px rgba(66, 217, 255, 0.28);
	}

	.evidence-section {
		margin: 0 0 118px;
		padding: 76px 0;
		border-block: 1px solid var(--ds-line-strong);
		background:
			linear-gradient(90deg, rgba(66, 217, 255, 0.08), transparent 34%),
			linear-gradient(180deg, rgba(2, 7, 10, 0.18), rgba(2, 7, 10, 0.58));
	}

	.evidence-section h2 {
		max-width: 920px;
		font-size: clamp(3.6rem, 9vw, 8.4rem);
		line-height: 0.86;
	}

	.evidence-lines {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 18px;
		margin-top: 42px;
	}

	.evidence-lines p {
		margin: 0;
		padding-top: 18px;
		border-top: 1px solid var(--ds-line);
		color: var(--ds-ink-soft);
		font-family: var(--ds-font-display);
		font-size: clamp(1.35rem, 2.4vw, 2.05rem);
		font-weight: 700;
		line-height: 1.08;
	}

	.state-panel h3 {
		margin-top: 24px;
		font-size: clamp(1.6rem, 2.8vw, 2.5rem);
		line-height: 1.02;
	}

	.state-copy {
		display: grid;
		gap: 16px;
	}

	.collaborate-card {
		grid-template-columns: minmax(0, 1fr) minmax(240px, 0.55fr) minmax(300px, 0.72fr);
	}

	.collaborate-card p {
		margin-top: 18px;
	}

	.collaborator-list {
		display: grid;
		gap: 10px;
	}

	.collaborator-list span {
		padding: 12px 14px;
		color: var(--ds-ink-soft);
		font-family: var(--ds-font-mono);
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.contact-panel {
		padding: 18px;
		border: 1px solid var(--ds-line);
		background: rgba(2, 7, 10, 0.32);
	}

	.contact-label {
		margin: 0 0 12px;
		color: var(--ds-blue);
		font-family: var(--ds-font-mono);
		font-size: 0.68rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.contact-panel a {
		display: inline-flex;
		margin-bottom: 12px;
		color: var(--ds-ink);
		font-family: var(--ds-font-display);
		font-size: 1.2rem;
		font-weight: 700;
		border-bottom: 1px solid var(--ds-blue);
	}

	.contact-panel p {
		margin-top: 0;
	}

	.public-footer {
		display: flex;
		justify-content: space-between;
		gap: 20px;
		padding: 34px 0 46px;
		border-top: 1px solid var(--ds-line);
		color: var(--ds-ink-muted);
		font-size: 0.86rem;
	}

	.public-footer p {
